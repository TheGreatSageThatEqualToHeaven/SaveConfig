HomeSection:AddSeparator()

local p = HomeSection:AddParagraph({ Title = "Credits", Content = "" })
p:SetColor(Color3.fromRGB(80, 255, 120))
task.spawn(function()
    local text = "Coded by Metamethod"
    while true do
        for i = 1, #text do p:Update(text:sub(1,i)) task.wait(0.05) end
        task.wait(1)
        for i = #text, 1, -1 do p:Update(text:sub(1,i)) task.wait(0.03) end
        p:Update("") task.wait(0.5)
    end
end)

