local WeatherSection = WorldTab:AddSection("Weather")

WeatherSection:AddDropdown({
    Title = "Weather Preset", Icon = "7733746980", -- cloud
    List = {"Clear", "Rainy", "Foggy", "Night", "Stormy", "Sunrise", "Sunset"},
    Default = "Clear"
}, function(v)
    local l = game:GetService("Lighting")
    if v == "Clear"   then l.ClockTime=14 l.Brightness=2   l.FogEnd=1e9
    elseif v=="Rainy" then l.ClockTime=12 l.Brightness=0.5 l.FogEnd=500
    elseif v=="Foggy" then l.ClockTime=12 l.Brightness=0.8 l.FogEnd=150
    elseif v=="Night" then l.ClockTime=0  l.Brightness=0.1 l.FogEnd=1e9
    elseif v=="Stormy"then l.ClockTime=10 l.Brightness=0.3 l.FogEnd=300
    elseif v=="Sunrise"then l.ClockTime=6 l.Brightness=1.2 l.FogEnd=800
    elseif v=="Sunset" then l.ClockTime=19 l.Brightness=1.5 l.FogEnd=700
    end
    Window:Notify({ Title = "Weather", Desc = v.." applied", Duration = 2, Kind = "info" })
end)

