    end

    local function loadManifest()
        if not readfile or not isfile then return end
        local path = getManifestPath()
        if not isfile(path) then return end
        local ok, raw = pcall(readfile, path)
        if not ok then return end
        local dok, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
        if dok and type(decoded) == "table" then
            for _, name in ipairs(decoded) do
                if type(name) == "string" and name ~= "" then
                    knownSavedConfigs[name] = true
                end
            end
        end
    end

    local function saveManifest()
        if not writefile then return end
        ensureFolder(configFolder)
        local names = {}
        for name, _ in pairs(knownSavedConfigs) do
            if not hiddenDeletedConfigs[name] then
                table.insert(names, name)
            end
        end
        table.sort(names)
        pcall(function() writefile(getManifestPath(), HttpService:JSONEncode(names)) end)
    end

