                    for _, c in ipairs(popup:GetDescendants()) do
                        if c:IsA("GuiObject") then tw(c, {BackgroundTransparency = 1}, 0.12) end
                        if c:IsA("TextLabel") or c:IsA("TextButton") then tw(c, {TextTransparency = 1}, 0.12) end
                        if c:IsA("ImageLabel") or c:IsA("ImageButton") then tw(c, {ImageTransparency = 1}, 0.12) end
                        if c:IsA("UIStroke") then tw(c, {Transparency = 1}, 0.12) end
                    end
                    task.delay(0.18, function()
                        if popup then popup:Destroy() popup = nil end
                        if popupOverlay then popupOverlay:Destroy() popupOverlay = nil end
                        activePopup = nil
                    end)
                else
                    if popupOverlay then popupOverlay:Destroy() popupOverlay = nil end
                    activePopup = nil
                end
                popupOpen = false
            end

