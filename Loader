                bindBtn.Activated:Connect(function()
                    if waiting then return end
                    waiting = true
                    bindBtn.Text = "Press a key..."
                    tw(bindBtn, {TextColor3 = T.ACCENT}, 0.1)
                end)

                local inputConn
                inputConn = UserInputService.InputBegan:Connect(function(input, gp)
                    if not waiting then return end
                    if gp then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == Enum.KeyCode.Escape then
                            boundKey = nil
                            bindBtn.Text = "Click to bind"
                            tw(bindBtn, {TextColor3 = T.ACCENT}, 0.1)
                            if holdConn then holdConn:Disconnect() holdConn = nil end
                        else
                            boundKey = input.KeyCode
                            bindBtn.Text = boundKey.Name
                            tw(bindBtn, {TextColor3 = T.ACCENT}, 0.1)
                        end
                        waiting = false
                    end
                end)

                -- Mode section
                local modeLbl = mkLabel(p, "Mode", 11, T.SUBTEXT)
                modeLbl.Size = UDim2.new(1, -20, 0, 16)
                modeLbl.Position = UDim2.new(0, 10, 0, 94)
