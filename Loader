local function mkLine(parent, pos, size, color, rotation)
    local l = Instance.new("Frame")
    l.Name = "IconLine"
    l.BackgroundColor3 = color or T.SUBTEXT
    l.BorderSizePixel = 0
    l.Size = size
    l.Position = pos
    l.AnchorPoint = Vector2.new(0.5, 0.5)
    l.Rotation = rotation or 0
    l.Parent = parent
    local thin = math.min(size.X.Offset, size.Y.Offset)
    corner(l, math.ceil(thin / 2))
    return l
end

local function mkCloseIcon(parent, size, color)
    local holder = Instance.new("Frame")
    holder.Name = "CloseIcon"
    holder.Size = UDim2.new(0, size, 0, size)
    holder.Position = UDim2.new(0.5, 0, 0.5, 0)
    holder.AnchorPoint = Vector2.new(0.5, 0.5)
    holder.BackgroundTransparency = 1
    holder.Parent = parent
    local thickness = math.max(2, math.round(size * 0.15))
    local length = math.round(size * 0.75)
    mkLine(holder, UDim2.new(0.5, 0, 0.5, 0), UDim2.new(0, length, 0, thickness), color or T.SUBTEXT, 45)
    mkLine(holder, UDim2.new(0.5, 0, 0.5, 0), UDim2.new(0, length, 0, thickness), color or T.SUBTEXT, -45)
    return holder
end

