local function setIconColor(iconHolder, color)
    for _, child in ipairs(iconHolder:GetChildren()) do
        if child:IsA("Frame") then
            child.BackgroundColor3 = color
        elseif child:IsA("TextLabel") or child:IsA("TextButton") then
            child.TextColor3 = color
        elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
            child.ImageColor3 = color
        end
    end
end

local function tweenIconColor(iconHolder, color, t)
    for _, child in ipairs(iconHolder:GetChildren()) do
        if child:IsA("Frame") then
            tw(child, {BackgroundColor3 = color}, t)
        elseif child:IsA("TextLabel") or child:IsA("TextButton") then
            tw(child, {TextColor3 = color}, t)
        elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
            tw(child, {ImageColor3 = color}, t)
        end
    end
end

local function setIconTransparency(iconHolder, transparency)
    for _, child in ipairs(iconHolder:GetChildren()) do
        if child:IsA("Frame") then
            child.BackgroundTransparency = transparency
        elseif child:IsA("TextLabel") or child:IsA("TextButton") then
            child.TextTransparency = transparency
        elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
            child.ImageTransparency = transparency
        end
