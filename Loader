                bindBtn.Text = "…"
                tw(bindBtn, {TextColor3 = T.TEXT})
            end)

            UserInputService.InputBegan:Connect(function(input, gp)
                if gp or not waiting then return end
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    key = input.KeyCode
                    bindBtn.Text = key.Name
                    tw(bindBtn, {TextColor3 = T.ACCENT})
                    waiting = false
                    pcall(cb, key)
                end
            end)


            onThemeChange(function()
                if not waiting then
                    tw(bindBtn, {TextColor3 = key and T.ACCENT or T.HINT})
                end
                tw(row, {BackgroundColor3 = T.BG3})
                tw(bindBtn, {BackgroundColor3 = T.BG4})
            end)

            local keybindObj = {
                Set = function(_, v)
                    key = v
                    bindBtn.Text = key and key.Name or "None"
                    tw(bindBtn, {TextColor3 = key and T.ACCENT or T.HINT})
                    pcall(cb, key)
                end,
                Get = function(_) return key end,
