            contentLbl.TextWrapped = true
            contentLbl.Name = "ParagraphContent"

            local paragraphObj = {}

            function paragraphObj:Update(newContent)
                if type(newContent) == "table" then
                    -- Support updating title and content
                    if newContent.Title and titleLbl then
                        titleLbl.Text = newContent.Title
                    end
                    if newContent.Content then
                        contentLbl.Text = newContent.Content
                    end
                else
                    contentLbl.Text = tostring(newContent)
                end
            end

            function paragraphObj:SetColor(color)
                contentLbl.TextColor3 = color
            end

            function paragraphObj:SetTitle(newTitle)
                if titleLbl then
                    titleLbl.Text = newTitle
                end
            end

            return paragraphObj
        end

