---------------------------------------------------------------------------
-- Theme refresh registry — all elements that need recoloring
---------------------------------------------------------------------------
local _themeBindings = {}
local function onThemeChange(fn)
    table.insert(_themeBindings, fn)
end
local function fireThemeChange()
    for _, fn in ipairs(_themeBindings) do
        pcall(fn)
    end
end

