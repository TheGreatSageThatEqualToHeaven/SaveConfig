-- Window
---------------------------------------------------------------------------
function SimpleUI.new(title, subtitle, config)
    local self = setmetatable({}, SimpleUI)
    
    -- Apply config before building UI
    config = config or {}
    if config.Theme and ThemePresets[config.Theme] then
        applyPreset(config.Theme)
    end
    if config.Accent then
        T.ACCENT = config.Accent
        -- Derive ACCENT2 from accent (slightly darker)
        local h, s, v = config.Accent:ToHSV()
        T.ACCENT2 = Color3.fromHSV(h, math.min(s + 0.15, 1), math.max(v - 0.15, 0))
    end
    if config.AccentAlt then
        T.ACCENT2 = config.AccentAlt
    end
    
    pcall(function()
        local old = CoreGui:FindFirstChild("SimpleUI_v2")
        if old then old:Destroy() end
    end)

    local sg = Instance.new("ScreenGui")
    sg.Name            = "SimpleUI_v2"
    sg.IgnoreGuiInset  = true
    sg.ResetOnSpawn    = false
    sg.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    sg.Parent          = CoreGui

    local win = mkFrame(sg, UDim2.new(0,750,0,500), UDim2.new(0.5,-375,0.5,-250), T.BG)
    win.ClipsDescendants = true
    corner(win, 14)
    mkStroke(win, T.SEP, 1, 0)
    self._win = win
    local activePopup = nil

    -- Glow effect behind the window (single soft glow, no inner ring)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.Parent = sg
    glow.BackgroundTransparency = 1
    glow.Image = "http://www.roblox.com/asset/?id=18245826428"
    glow.ImageColor3 = T.ACCENT
    glow.ImageTransparency = 0.72
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(Vector2.new(21, 21), Vector2.new(79, 79))
    glow.ZIndex = 0
    -- corner(glow, 18)
    glow.Size = UDim2.new(0, 750 + 34, 0, 500 + 36)
    glow.Position = UDim2.new(0.5, -375 - 17, 0.5, -250 - 19)

    -- Keep glow synced with window position and size
    local function syncGlow()
        glow.Position = UDim2.new(
            win.Position.X.Scale, win.Position.X.Offset - 17,
            win.Position.Y.Scale, win.Position.Y.Offset - 19
        )
        glow.Size = UDim2.new(
            win.Size.X.Scale, win.Size.X.Offset + 34,
            win.Size.Y.Scale, win.Size.Y.Offset + 36
        )
        glow.Visible = win.Visible
    end

    win:GetPropertyChangedSignal("Position"):Connect(syncGlow)
    win:GetPropertyChangedSignal("Size"):Connect(syncGlow)
    win:GetPropertyChangedSignal("Visible"):Connect(syncGlow)
    self._glow = glow


    -- Track elements for theme refresh
    local winStroke = win:FindFirstChildOfClass("UIStroke")

    -- Resize dragger (bottom-right corner)
    local resizing = false
    do
        local resizeDragger = Instance.new("ImageLabel")
        resizeDragger.Name = "resize"
        resizeDragger.Size = UDim2.new(0, 20, 0, 20)
        resizeDragger.Position = UDim2.new(1, -25, 1, -25)
        resizeDragger.BackgroundTransparency = 1
        resizeDragger.Image = "rbxassetid://6031091004" -- resize icon
        resizeDragger.ImageColor3 = T.SUBTEXT
        resizeDragger.ImageTransparency = 0.5
        resizeDragger.ZIndex = 100
        resizeDragger.Parent = win

        local isResizing = false
        local startPosition, startSize = nil, nil

        local function getInputPos(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                return Vector2.new(input.Position.X, input.Position.Y)
            else
                return UserInputService:GetMouseLocation()
            end
        end

        local minSize = Vector2.new(500, 350)

        resizeDragger.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isResizing = true
                resizing = true
                startPosition = getInputPos(input)
                startSize = win.AbsoluteSize
                TweenService:Create(resizeDragger, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 15, 0, 15)}):Play()
                TweenService:Create(resizeDragger, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local mouse = getInputPos(input)
                if startPosition and mouse then
                    local delta = mouse - startPosition
                    local newWidth = math.max(minSize.X, startSize.X + delta.X)
                    local newHeight = math.max(minSize.Y, startSize.Y + delta.Y)
                    win:TweenSize(
                        UDim2.fromOffset(newWidth, newHeight),
                        Enum.EasingDirection.Out,
                        Enum.EasingStyle.Quint,
                        0.4,
                        true
                    )
                end
            end
        end)

        resizeDragger.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isResizing = false
                resizing = false
                startPosition, startSize = nil, nil
                TweenService:Create(resizeDragger, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 20, 0, 20)}):Play()
                TweenService:Create(resizeDragger, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {ImageColor3 = T.SUBTEXT}):Play()
            end
        end)
    end

    -- Top bar
    local topBar = mkFrame(win, UDim2.new(1,0,0,44), nil, T.BG2)
    corner(topBar, 10)
    local topBarFill = mkFrame(topBar, UDim2.new(1,0,0,10), UDim2.new(0,0,1,-10), T.BG2)

    local pill = mkFrame(topBar, UDim2.new(0,3,0,20), UDim2.new(0,12,0.5,-10), T.ACCENT)
    corner(pill, 4)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position = UDim2.new(0,24,0,0)
    titleLbl.Size     = UDim2.new(1,-140,1,0)
    titleLbl.Font     = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.TextColor3 = T.TEXT
    titleLbl.Text     = title or "UI"
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent   = topBar

    if subtitle then
        local sub = Instance.new("TextLabel")
        sub.BackgroundTransparency = 1
        sub.Position = UDim2.new(0, 24 + titleLbl.TextBounds.X + 10, 0, 0)
        sub.Size     = UDim2.new(0,200,1,0)
        sub.Font     = Enum.Font.Gotham
        sub.TextSize = 12
        sub.TextColor3 = T.SUBTEXT
        sub.Text     = subtitle
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.Parent   = titleContainer
    end


    -- *** Title bounce animation on load ***
    -- Group pill + title + subtitle into a container for unified animation
    local titleContainer = Instance.new("Frame")
    titleContainer.Name = "TitleContainer"
    titleContainer.BackgroundTransparency = 1
    titleContainer.Size = UDim2.new(1, -140, 1, 0)
    titleContainer.Position = UDim2.new(0, 0, 0, 0)
    titleContainer.ClipsDescendants = false
    titleContainer.Parent = topBar

    -- Re-parent pill, titleLbl, subtitle into container
    pill.Parent = titleContainer
    pill.Position = UDim2.new(0, 12, 0.5, -10)
    titleLbl.Parent = titleContainer
    titleLbl.Position = UDim2.new(0, 24, 0, 0)
    titleLbl.Size = UDim2.new(1, 0, 1, 0)

    -- Set initial state: shifted right and scaled wider
    titleContainer.Position = UDim2.new(0, 0, 0, 0)
    pill.Size = UDim2.new(0, 3, 0, 20)


    -- HD top bar buttons using frame-drawn icons
    local function mkTopBtn(iconType, xoff)
        local b = Instance.new("TextButton")
        b.Size            = UDim2.new(0,28,0,28)
        b.Position        = UDim2.new(1,xoff,0.5,-14)
        b.BackgroundColor3= T.BG3
        b.Text            = ""
        b.BorderSizePixel = 0
        b.Parent          = topBar
        corner(b, 7)

        local icon
        if iconType == "close" then
            icon = mkCloseIcon(b, 14, T.SUBTEXT)
        elseif iconType == "minimize" then
            icon = mkMinimizeIcon(b, 14, T.SUBTEXT)
        elseif iconType == "gear" then
            icon = mkGearIcon(b, 14, T.SUBTEXT)
        elseif iconType == "search" then
            icon = mkSearchIcon(b, 14, T.SUBTEXT)
