    local function performSearch(query)
        clearResults()
        if query == "" then return end

        local q = string.lower(query)
        local matches = {}
        for _, entry in ipairs(self._featureRegistry) do
            local title = string.lower(entry.title or "")
            local tab = string.lower(entry.tabName or "")
            local sec = string.lower(entry.sectionName or "")
            if string.find(title, q, 1, true) or string.find(tab, q, 1, true) or string.find(sec, q, 1, true) then
                table.insert(matches, entry)
            end
        end

        if #matches == 0 then
            noResultsLbl.Text = "No results for \"" .. query .. "\""
            noResultsLbl.Visible = true
            return
        end

        -- Build result cards with domino animation
        for idx, entry in ipairs(matches) do
            local resultRow = mkFrame(searchResultsScroll, UDim2.new(1, 0, 0, 44), nil, T.BG2)
            resultRow.ZIndex = 62
            resultRow.ClipsDescendants = true
            corner(resultRow, 8)
            mkStroke(resultRow, T.HINT, 1, 0.5)
            pad(resultRow, 0, 0, 12, 12)

            -- Start hidden for domino
            resultRow.BackgroundTransparency = 1
            resultRow.Size = UDim2.new(1, 0, 0, 0)

            local titleLbl2 = mkLabel(resultRow, entry.title or "Feature", 13, T.TEXT)
            titleLbl2.Size = UDim2.new(1, -80, 0, 18)
            titleLbl2.Position = UDim2.new(0, 0, 0, 4)
            titleLbl2.ZIndex = 63
            titleLbl2.TextTransparency = 1

            local breadcrumb = mkLabel(resultRow, (entry.tabName or "") .. " › " .. (entry.sectionName or ""), 10, T.SUBTEXT)
            breadcrumb.Size = UDim2.new(1, -80, 0, 14)
            breadcrumb.Position = UDim2.new(0, 0, 0, 24)
            breadcrumb.ZIndex = 63
            breadcrumb.TextTransparency = 1

            -- Arrow indicator
            local arrowHolder2 = Instance.new("Frame")
            arrowHolder2.Size = UDim2.new(0, 16, 0, 16)
            arrowHolder2.Position = UDim2.new(1, -16, 0.5, -8)
            arrowHolder2.BackgroundTransparency = 1
            arrowHolder2.ZIndex = 63
            arrowHolder2.Parent = resultRow
            local arrowIcon2 = mkArrowIcon(arrowHolder2, 12, T.SUBTEXT)
            setIconTransparency(arrowIcon2, 1)

            -- Click area
            local resultBtn = Instance.new("TextButton")
            resultBtn.Size = UDim2.new(1, 0, 1, 0)
            resultBtn.BackgroundTransparency = 1
            resultBtn.Text = ""
            resultBtn.ZIndex = 64
            resultBtn.Parent = resultRow

            resultBtn.MouseEnter:Connect(function()
                tw(resultRow, {BackgroundColor3 = T.BG3})
            end)
            resultBtn.MouseLeave:Connect(function()
                tw(resultRow, {BackgroundColor3 = T.BG2})
            end)
            resultBtn.MouseButton1Click:Connect(function()
                -- Navigate to the tab
                if entry.activate then
                    pcall(entry.activate)
                end
                -- Close search
                closeSearch()
                -- Scroll to the feature element if available
                if entry.element then
                    task.delay(0.35, function()
                        local scrollFrame = self._scroll
                        local elY = entry.element.AbsolutePosition.Y - scrollFrame.AbsolutePosition.Y + scrollFrame.CanvasPosition.Y
                        local targetY = math.max(0, elY - 10)
                        tw(scrollFrame, {CanvasPosition = Vector2.new(0, targetY)}, 0.35, Enum.EasingStyle.Quint)
                    end)
                end
            end)

            table.insert(currentResultFrames, resultRow)

            -- Domino stagger animation
            local DOMINO_DELAY = 0.06
            task.delay(idx * DOMINO_DELAY, function()
                tw(resultRow, {Size = UDim2.new(1, 0, 0, 44), BackgroundTransparency = 0}, 0.3, Enum.EasingStyle.Back)
                task.delay(0.05, function()
                    tw(titleLbl2, {TextTransparency = 0}, 0.25)
                    tw(breadcrumb, {TextTransparency = 0}, 0.25)
                    tweenIconTransparency(arrowIcon2, 0, 0.25)
                end)
            end)
        end
    end

    -- Debounce search
    local searchDebounce = nil
    searchInput:GetPropertyChangedSignal("Text"):Connect(function()
        if searchDebounce then task.cancel(searchDebounce) end
        searchDebounce = task.delay(0.15, function()
            performSearch(searchInput.Text)
        end)
    end)

    local function openSearch()
        if searchOpen then return end
        searchOpen = true
        setOverlayDividerHidden(true)
        searchPanel.Visible = true
        searchPanel.BackgroundTransparency = 1
        searchInputBg.BackgroundTransparency = 1
        searchInput.TextTransparency = 1
        noResultsLbl.Visible = false
        clearResults()
        searchInput.Text = ""

        -- Reset close button visibility
        searchCloseBtn.BackgroundTransparency = 1
        for _, line in ipairs(searchCloseIcon:GetChildren()) do
            if line:IsA("Frame") then line.BackgroundTransparency = 1 end
        end
        for _, child in ipairs(searchCloseBtn:GetChildren()) do
            if child:IsA("UIStroke") then child.Transparency = 1 end
        end
        -- Reset search icon visibility
        searchIcon2.ImageTransparency = 1
        for _, child in ipairs(searchIcon2:GetDescendants()) do
            if child:IsA("Frame") then child.BackgroundTransparency = 1 end
            if child:IsA("UIStroke") then child.Transparency = 1 end
        end
        -- Reset input stroke
        for _, child in ipairs(searchInputBg:GetChildren()) do
            if child:IsA("UIStroke") then child.Transparency = 1 end
        end

        tw(searchPanel, {BackgroundTransparency = 0}, 0.3, Enum.EasingStyle.Exponential)
        task.delay(0.1, function()
            tw(searchInputBg, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
            tw(searchInput, {TextTransparency = 0}, 0.25)
            tw(searchCloseBtn, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
            for _, line in ipairs(searchCloseIcon:GetChildren()) do
                if line:IsA("Frame") then tw(line, {BackgroundTransparency = 0}, 0.25) end
            end
            for _, child in ipairs(searchCloseBtn:GetChildren()) do
                if child:IsA("UIStroke") then tw(child, {Transparency = 0.3}, 0.25) end
            end
            tw(searchIcon2, {ImageTransparency = 0}, 0.25)
            for _, child in ipairs(searchIcon2:GetDescendants()) do
                if child:IsA("Frame") then tw(child, {BackgroundTransparency = 0}, 0.25) end
                if child:IsA("UIStroke") then tw(child, {Transparency = 0}, 0.25) end
            end
            for _, child in ipairs(searchInputBg:GetChildren()) do
                if child:IsA("UIStroke") then tw(child, {Transparency = 0.3}, 0.25) end
            end
        end)
        task.delay(0.2, function()
            searchInput:CaptureFocus()
        end)
    end

    closeSearch = function()
        if not searchOpen then return end
        searchOpen = false
        setOverlayDividerHidden(false)

        local dur = 0.2

        -- Fade everything at the same time
        for _, f in ipairs(currentResultFrames) do
            tw(f, {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)}, dur, Enum.EasingStyle.Quint)
            -- Fade child labels too
            for _, child in ipairs(f:GetDescendants()) do
                if child:IsA("TextLabel") then
                    tw(child, {TextTransparency = 1}, dur, Enum.EasingStyle.Quint)
                elseif child:IsA("Frame") then
                    tw(child, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint)
                elseif child:IsA("UIStroke") then
                    tw(child, {Transparency = 1}, dur, Enum.EasingStyle.Quint)
                end
            end
        end

        tw(searchInputBg, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint)
        tw(searchInput, {TextTransparency = 1}, dur, Enum.EasingStyle.Quint)
        tw(searchCloseBtn, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint)
        for _, line in ipairs(searchCloseIcon:GetChildren()) do
            if line:IsA("Frame") then tw(line, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint) end
        end
        -- Fade strokes on input and close button
        for _, child in ipairs(searchInputBg:GetChildren()) do
            if child:IsA("UIStroke") then tw(child, {Transparency = 1}, dur, Enum.EasingStyle.Quint) end
        end
        for _, child in ipairs(searchCloseBtn:GetChildren()) do
            if child:IsA("UIStroke") then tw(child, {Transparency = 1}, dur, Enum.EasingStyle.Quint) end
        end
        -- Fade search icon
        tw(searchIcon2, {ImageTransparency = 1}, dur, Enum.EasingStyle.Quint)
        for _, child in ipairs(searchIcon2:GetDescendants()) do
            if child:IsA("Frame") then tw(child, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint) end
            if child:IsA("UIStroke") then tw(child, {Transparency = 1}, dur, Enum.EasingStyle.Quint) end
        end
        tw(noResultsLbl, {TextTransparency = 1}, dur, Enum.EasingStyle.Quint)
        tw(searchPanel, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quint)

        task.delay(dur + 0.02, function()
            searchPanel.Visible = false
            clearResults()
            searchInput.Text = ""
            noResultsLbl.Visible = false
        end)
    end

    searchCloseBtn.MouseButton1Click:Connect(closeSearch)
    searchBtn.MouseButton1Click:Connect(function()
        if searchOpen then
            closeSearch()
        else
            if settingsOpen then closeSettings() end
            openSearch()
        end
    end)

    -- Theme refresh for search panel
    onThemeChange(function()
        tw(searchPanel, {BackgroundColor3 = T.BG})
        tw(searchInputBg, {BackgroundColor3 = T.BG2})
        tw(searchInput, {TextColor3 = T.TEXT})
        tw(searchCloseBtn, {BackgroundColor3 = T.BG2})
        tw(noResultsLbl, {TextColor3 = T.SUBTEXT})
        for _, f in ipairs(currentResultFrames) do
            tw(f, {BackgroundColor3 = T.BG2})
        end
    end)


    local confirmOverlay = mkFrame(body, UDim2.new(1,0,1,0), UDim2.new(0,0,0,0), Color3.new(0,0,0), 1)
    confirmOverlay.Name = "ConfirmOverlay"
    confirmOverlay.ZIndex = 80
    confirmOverlay.Visible = false
    confirmOverlay.ClipsDescendants = true
    corner(confirmOverlay, 14)

    local confirmCard = mkFrame(confirmOverlay, UDim2.new(0,280,0,0), UDim2.new(0.5,-140,0.5,0), T.BG2)
    confirmCard.AnchorPoint = Vector2.new(0, 0.5)
    confirmCard.ZIndex = 81
    confirmCard.ClipsDescendants = true
    confirmCard.AutomaticSize = Enum.AutomaticSize.Y
    corner(confirmCard, 12)
    mkStroke(confirmCard, T.HINT, 1, 0.3)

    local confirmPad = Instance.new("UIPadding")
    confirmPad.PaddingTop    = UDim.new(0, 20)
    confirmPad.PaddingBottom = UDim.new(0, 20)
    confirmPad.PaddingLeft   = UDim.new(0, 20)
    confirmPad.PaddingRight  = UDim.new(0, 20)
    confirmPad.Parent        = confirmCard
    local confirmLayout = mkList(confirmCard, 10)

    -- Icon circle
    local confirmIconCircle = mkFrame(confirmCard, UDim2.new(0,36,0,36), nil, T.ACCENT, 0.88)
    confirmIconCircle.ZIndex = 82
    corner(confirmIconCircle, 18)

    local confirmIconLbl = Instance.new("TextLabel")
    confirmIconLbl.BackgroundTransparency = 1
    confirmIconLbl.Size = UDim2.new(1,0,1,0)
    confirmIconLbl.Text = "?"
    confirmIconLbl.Font = Enum.Font.GothamBold
    confirmIconLbl.TextSize = 18
    confirmIconLbl.TextColor3 = T.ACCENT
    confirmIconLbl.TextXAlignment = Enum.TextXAlignment.Center
    confirmIconLbl.ZIndex = 83
    confirmIconLbl.Parent = confirmIconCircle

    -- Title
    local confirmTitleLbl = Instance.new("TextLabel")
    confirmTitleLbl.BackgroundTransparency = 1
    confirmTitleLbl.Size = UDim2.new(1,0,0,20)
    confirmTitleLbl.Font = Enum.Font.GothamBold
    confirmTitleLbl.TextSize = 15
    confirmTitleLbl.TextColor3 = T.TEXT
    confirmTitleLbl.Text = "Are you sure?"
    confirmTitleLbl.TextXAlignment = Enum.TextXAlignment.Left
    confirmTitleLbl.ZIndex = 82
    confirmTitleLbl.Parent = confirmCard

    -- Description
    local confirmDescLbl = Instance.new("TextLabel")
    confirmDescLbl.BackgroundTransparency = 1
    confirmDescLbl.Size = UDim2.new(1,0,0,0)
    confirmDescLbl.AutomaticSize = Enum.AutomaticSize.Y
    confirmDescLbl.Font = Enum.Font.Gotham
    confirmDescLbl.TextSize = 12
    confirmDescLbl.TextColor3 = T.SUBTEXT
    confirmDescLbl.Text = "This action cannot be undone."
    confirmDescLbl.TextXAlignment = Enum.TextXAlignment.Left
    confirmDescLbl.TextWrapped = true
    confirmDescLbl.ZIndex = 82
    confirmDescLbl.Parent = confirmCard

    -- Button row
    local confirmBtnRow = mkFrame(confirmCard, UDim2.new(1,0,0,34), nil, Color3.new(0,0,0), 1)
    confirmBtnRow.ZIndex = 82

    -- Cancel button
    local confirmCancelBtn = Instance.new("TextButton")
    confirmCancelBtn.Size = UDim2.new(0.48, 0, 0, 34)
    confirmCancelBtn.Position = UDim2.new(0, 0, 0, 0)
    confirmCancelBtn.BackgroundColor3 = T.BG3
    confirmCancelBtn.Font = Enum.Font.GothamMedium
    confirmCancelBtn.TextSize = 13
    confirmCancelBtn.TextColor3 = T.TEXT
    confirmCancelBtn.Text = "Cancel"
    confirmCancelBtn.BorderSizePixel = 0
    confirmCancelBtn.ZIndex = 83
    confirmCancelBtn.Parent = confirmBtnRow
    corner(confirmCancelBtn, 8)
    mkStroke(confirmCancelBtn, T.HINT, 1, 0.4)

    -- Confirm button
    local confirmYesBtn = Instance.new("TextButton")
    confirmYesBtn.Size = UDim2.new(0.48, 0, 0, 34)
    confirmYesBtn.Position = UDim2.new(0.52, 0, 0, 0)
    confirmYesBtn.BackgroundColor3 = T.ACCENT
    confirmYesBtn.Font = Enum.Font.GothamBold
    confirmYesBtn.TextSize = 13
    confirmYesBtn.TextColor3 = Color3.new(1, 1, 1)
    confirmYesBtn.Text = "Confirm"
    confirmYesBtn.BorderSizePixel = 0
    confirmYesBtn.ZIndex = 83
    confirmYesBtn.Parent = confirmBtnRow
    corner(confirmYesBtn, 8)

    -- Hover effects
    confirmCancelBtn.MouseEnter:Connect(function() tw(confirmCancelBtn, {BackgroundColor3 = T.BG4}) end)
    confirmCancelBtn.MouseLeave:Connect(function() tw(confirmCancelBtn, {BackgroundColor3 = T.BG3}) end)
    confirmYesBtn.MouseEnter:Connect(function() tw(confirmYesBtn, {BackgroundColor3 = T.ACCENT2}) end)
    confirmYesBtn.MouseLeave:Connect(function() tw(confirmYesBtn, {BackgroundColor3 = T.ACCENT}) end)

    local _confirmCallback = nil

    local function showConfirm(opts2, onConfirm)
        opts2 = opts2 or {}
        confirmTitleLbl.Text = opts2.Title or "Are you sure?"
        confirmDescLbl.Text = opts2.Desc or "This action cannot be undone."
        confirmYesBtn.Text = opts2.ConfirmText or "Confirm"
        confirmCancelBtn.Text = opts2.CancelText or "Cancel"
        _confirmCallback = onConfirm

        -- Reset state for animation
        confirmOverlay.Visible = true
        confirmOverlay.BackgroundTransparency = 1
        confirmCard.BackgroundTransparency = 1
        confirmCard.Size = UDim2.new(0, 280, 0, 0)
        confirmCard.Position = UDim2.new(0.5, -140, 0.5, 0)

        -- Hide all text initially
        confirmTitleLbl.TextTransparency = 1
        confirmDescLbl.TextTransparency = 1
        confirmIconLbl.TextTransparency = 1
        confirmIconCircle.BackgroundTransparency = 1
        confirmCancelBtn.BackgroundTransparency = 1
        confirmCancelBtn.TextTransparency = 1
        confirmYesBtn.BackgroundTransparency = 1
        confirmYesBtn.TextTransparency = 1
        local cancelStroke = confirmCancelBtn:FindFirstChildOfClass("UIStroke")
        if cancelStroke then cancelStroke.Transparency = 1 end
        local cardStroke = confirmCard:FindFirstChildOfClass("UIStroke")
        if cardStroke then cardStroke.Transparency = 1 end

        -- Animate overlay dim
        tw(confirmOverlay, {BackgroundTransparency = 0.4}, 0.3, Enum.EasingStyle.Exponential)

        -- Animate card scale in + restore border
        tw(confirmCard, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
        if cardStroke then tw(cardStroke, {Transparency = 0.3}, 0.25, Enum.EasingStyle.Exponential) end

        -- Stagger content
        task.delay(0.08, function()
            tw(confirmIconCircle, {BackgroundTransparency = 0.88}, 0.25, Enum.EasingStyle.Exponential)
            tw(confirmIconLbl, {TextTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
        end)
        task.delay(0.12, function()
            tw(confirmTitleLbl, {TextTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
        end)
        task.delay(0.16, function()
            tw(confirmDescLbl, {TextTransparency = 0}, 0.25, Enum.EasingStyle.Exponential)
        end)
        task.delay(0.20, function()
            tw(confirmCancelBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.22, Enum.EasingStyle.Exponential)
            if cancelStroke then tw(cancelStroke, {Transparency = 0.4}, 0.22) end
            tw(confirmYesBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.22, Enum.EasingStyle.Exponential)
        end)
    end

    local function hideConfirm(didConfirm)
        local cancelStroke = confirmCancelBtn:FindFirstChildOfClass("UIStroke")
        local cardStroke = confirmCard:FindFirstChildOfClass("UIStroke")

        -- Fade ALL elements together with one shared duration so nothing lingers
        local dur = 0.18

        -- Content
        tw(confirmCancelBtn, {BackgroundTransparency = 1, TextTransparency = 1}, dur, Enum.EasingStyle.Quad)
        tw(confirmYesBtn, {BackgroundTransparency = 1, TextTransparency = 1}, dur, Enum.EasingStyle.Quad)
        if cancelStroke then tw(cancelStroke, {Transparency = 1}, dur, Enum.EasingStyle.Quad) end
        tw(confirmDescLbl, {TextTransparency = 1}, dur, Enum.EasingStyle.Quad)
        tw(confirmTitleLbl, {TextTransparency = 1}, dur, Enum.EasingStyle.Quad)
        tw(confirmIconLbl, {TextTransparency = 1}, dur, Enum.EasingStyle.Quad)
        tw(confirmIconCircle, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quad)

        -- Card + its stroke + overlay — same duration, same easing, started at the same frame
        tw(confirmCard, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quad)
        if cardStroke then tw(cardStroke, {Transparency = 1}, dur, Enum.EasingStyle.Quad) end
        tw(confirmOverlay, {BackgroundTransparency = 1}, dur, Enum.EasingStyle.Quad)

        task.delay(dur + 0.02, function()
            confirmOverlay.Visible = false
            if didConfirm and _confirmCallback then
                pcall(_confirmCallback)
            end
            _confirmCallback = nil
        end)
    end

    confirmCancelBtn.MouseButton1Click:Connect(function() hideConfirm(false) end)
    confirmYesBtn.MouseButton1Click:Connect(function() hideConfirm(true) end)

    -- Store on self for section access
    self._showConfirm = showConfirm

    -- Theme refresh for confirm dialog
    onThemeChange(function()
        tw(confirmCard, {BackgroundColor3 = T.BG2})
        tw(confirmTitleLbl, {TextColor3 = T.TEXT})
        tw(confirmDescLbl, {TextColor3 = T.SUBTEXT})
        tw(confirmCancelBtn, {BackgroundColor3 = T.BG3, TextColor3 = T.TEXT})
        tw(confirmYesBtn, {BackgroundColor3 = T.ACCENT})
        tw(confirmIconCircle, {BackgroundColor3 = T.ACCENT})
        tw(confirmIconLbl, {TextColor3 = T.ACCENT})
    end)



    return self
end

---------------------------------------------------------------------------
-- Tabs — with real domino cascade on load
---------------------------------------------------------------------------
function SimpleUI:AddTab(name, icon)
    local windowSelf = self
    self._tabCounter = self._tabCounter + 1
    local tabIndex = self._tabCounter
    local DOMINO_DELAY = 0.1

    local wrapper = Instance.new("Frame")
    wrapper.Size              = UDim2.new(1, 0, 0, 0)
    wrapper.BackgroundTransparency = 1
    wrapper.BorderSizePixel   = 0
    wrapper.ClipsDescendants  = true
    wrapper.LayoutOrder       = tabIndex
    wrapper.Parent            = self._sidebar

    local btn = Instance.new("TextButton")
    btn.Size              = UDim2.new(1,0,0,34)
    btn.Position          = UDim2.new(0, -40, 0, 0)
    btn.BackgroundColor3  = T.BG3
    btn.BackgroundTransparency = 1
    btn.Text              = ""
    btn.BorderSizePixel   = 0
    btn.Parent            = wrapper
    corner(btn, 7)

    local bar = mkFrame(btn, UDim2.new(0,0,0,18), UDim2.new(0,4,0.5,-9), T.ACCENT)
    corner(bar, 4)
    bar.BackgroundTransparency = 1

    -- Support both emoji (TextLabel) and rbxassetid:// (ImageLabel) icons like Syde
    local isImageIcon = icon and (string.sub(icon, 1, 13) == "rbxassetid://" or string.match(icon, "^%d+$"))
    local iconLbl
    local iconIsImage = false

    if isImageIcon then
        iconIsImage = true
        local imageId = icon
        if string.match(icon, "^%d+$") then imageId = "rbxassetid://" .. icon end
        iconLbl = Instance.new("ImageLabel")
        iconLbl.Name = "TabIcon"
        iconLbl.BackgroundTransparency = 1
        iconLbl.Position = UDim2.new(0, 10, 0.5, 0)
        iconLbl.AnchorPoint = Vector2.new(0, 0.5)
        iconLbl.Size = UDim2.new(0, 16, 0, 16)
        iconLbl.Image = imageId
        iconLbl.ImageColor3 = T.SUBTEXT
        iconLbl.ImageTransparency = 1
        iconLbl.ScaleType = Enum.ScaleType.Fit
        iconLbl.Parent = btn
    else
        iconLbl = Instance.new("TextLabel")
        iconLbl.BackgroundTransparency = 1
        iconLbl.Position   = UDim2.new(0,10,0,0)
        iconLbl.Size       = UDim2.new(0,18,1,0)
        iconLbl.TextSize   = 14
        iconLbl.Text       = icon or ""
        iconLbl.Font       = Enum.Font.GothamBold
        iconLbl.TextColor3 = T.SUBTEXT
        iconLbl.TextTransparency = 1
        iconLbl.Parent     = btn
    end

    local nameLbl = mkLabel(btn, name, 13, T.SUBTEXT)
    nameLbl.Position = UDim2.new(0, icon and 32 or 12, 0, 0)
    nameLbl.Size     = UDim2.new(1, icon and -32 or -12, 1, 0)
    nameLbl.TextTransparency = 1

    -- Domino animation
    task.delay(tabIndex * DOMINO_DELAY, function()
        tw(wrapper, {Size = UDim2.new(1, 0, 0, 34)}, 0.3, Enum.EasingStyle.Back)
        task.delay(0.05, function()
            tw(btn, {Position = UDim2.new(0, 0, 0, 0)}, 0.35, Enum.EasingStyle.Back)
            tw(nameLbl, {TextTransparency = 0}, 0.3)
            if iconIsImage then
                tw(iconLbl, {ImageTransparency = 0}, 0.3)
            else
                tw(iconLbl, {TextTransparency = 0}, 0.3)
            end
        end)
    end)

    local container = mkFrame(self._scroll, UDim2.new(1,0,0,0), nil, Color3.new(0,0,0), 1)
    container.Name           = name
    container.Visible        = false
    container.AutomaticSize  = Enum.AutomaticSize.Y
    local conList = mkList(container, 8)

    local tabObj = { _container = container }

    local function activate()
        for _, t in pairs(self._tabs) do t._container.Visible = false end
        for _, b in pairs(self._tabBtns) do
            tw(b.btn, {BackgroundTransparency = 1})
            tw(b.name, {TextColor3 = T.SUBTEXT})
            if b.isImage then
                tw(b.icon, {ImageColor3 = T.SUBTEXT})
            else
                tw(b.icon, {TextColor3 = T.SUBTEXT})
            end
            tw(b.bar, {Size = UDim2.new(0,0,0,18), Position = UDim2.new(0,7.5,0.5,-9)}, 0.15)
            tw(b.bar, {BackgroundTransparency = 1}, 0.15)
        end
        container.Visible = true
        tw(btn,     {BackgroundTransparency = 0, BackgroundColor3 = T.BG3})
        tw(nameLbl, {TextColor3 = T.TEXT})
        if iconIsImage then
            tw(iconLbl, {ImageColor3 = T.TEXT})
        else
            tw(iconLbl, {TextColor3 = T.TEXT})
        end

        bar.Size     = UDim2.new(0, 0, 0, 18)
        bar.Position = UDim2.new(0, 10, 0.5, -9)
        tw(bar, {BackgroundTransparency = 0}, 0.1)
        tw(bar, {Size = UDim2.new(0, 3, 0, 18), Position = UDim2.new(0, 4, 0.5, -9)}, 0.25, Enum.EasingStyle.Quint)

        self._activeTab = tabObj
        self._scroll.CanvasPosition = Vector2.new(0,0)
    end

    btn.MouseButton1Click:Connect(activate)
    btn.MouseEnter:Connect(function()
        if self._activeTab ~= tabObj then
            tw(btn, {BackgroundTransparency = 0.5, BackgroundColor3 = T.BG3})
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab ~= tabObj then
            tw(btn, {BackgroundTransparency = 1})
        end
    end)

    table.insert(self._tabBtns, {btn=btn, name=nameLbl, icon=iconLbl, bar=bar, isImage=iconIsImage})
    table.insert(self._tabs, tabObj)

    -- Update tab colors immediately when theme changes (use tw to override active tweens)
    onThemeChange(function()
        tw(bar, {BackgroundColor3 = T.ACCENT}, 0.01)
        if self._activeTab == tabObj then
            tw(btn, {BackgroundColor3 = T.BG3, BackgroundTransparency = 0}, 0.01)
            tw(nameLbl, {TextColor3 = T.TEXT}, 0.01)
            if iconIsImage then
                tw(iconLbl, {ImageColor3 = T.TEXT}, 0.01)
            else
                tw(iconLbl, {TextColor3 = T.TEXT}, 0.01)
            end
        else
            tw(btn, {BackgroundTransparency = 1}, 0.01)
            tw(nameLbl, {TextColor3 = T.SUBTEXT}, 0.01)
            if iconIsImage then
                tw(iconLbl, {ImageColor3 = T.SUBTEXT}, 0.01)
            else
                tw(iconLbl, {TextColor3 = T.SUBTEXT}, 0.01)
            end
        end
    end)

    if #self._tabs == 1 then
        task.delay(tabIndex * DOMINO_DELAY + 0.4, activate)
    end

    ---------------------------------------------------------------------------
    -- Section
    ---------------------------------------------------------------------------
    function tabObj:AddSection(secName)
        local card = mkFrame(container, UDim2.new(1,0,0,0), nil, T.BG2)
        card.AutomaticSize  = Enum.AutomaticSize.Y
        card.ClipsDescendants = false
        corner(card, 9)
        mkStroke(card, T.SEP, 1, 0)
        pad(card, 12, 12, 12, 12)
        local cardList = mkList(card, 7)

        local hdr = mkFrame(card, UDim2.new(1,0,0,24), nil, Color3.new(0,0,0), 1)
        local hdrLbl = mkLabel(hdr, secName, 11, T.SUBTEXT)
