            corner(hueBar, 6)
            hueBar.ClipsDescendants = true

            -- Use UIGradient for a smooth hue bar instead of discrete slices
            local hueGrad = Instance.new("UIGradient")
            hueGrad.Rotation = 90
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(0.091, Color3.fromHSV(0.091, 1, 1)),
                ColorSequenceKeypoint.new(0.182, Color3.fromHSV(0.182, 1, 1)),
                ColorSequenceKeypoint.new(0.273, Color3.fromHSV(0.273, 1, 1)),
                ColorSequenceKeypoint.new(0.364, Color3.fromHSV(0.364, 1, 1)),
                ColorSequenceKeypoint.new(0.455, Color3.fromHSV(0.455, 1, 1)),
                ColorSequenceKeypoint.new(0.545, Color3.fromHSV(0.545, 1, 1)),
                ColorSequenceKeypoint.new(0.636, Color3.fromHSV(0.636, 1, 1)),
                ColorSequenceKeypoint.new(0.727, Color3.fromHSV(0.727, 1, 1)),
                ColorSequenceKeypoint.new(0.818, Color3.fromHSV(0.818, 1, 1)),
                ColorSequenceKeypoint.new(0.909, Color3.fromHSV(0.909, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            })
            hueGrad.Parent = hueBar

