        function secObj:AddSlider(opts, cb)
            opts = opts or {}
            local min  = opts.Min     or 0
            local max  = opts.Max     or 100
            local val  = math.clamp(opts.Default or min, min, max)
            local prec = opts.Precise or false
            cb = cb or function() end

            local row = mkFrame(card, UDim2.new(1,0,0,56), nil, T.BG3)
            registerFeature(opts.Title or "Slider", row)
            corner(row, 7)
            pad(row, 0, 0, 12, 12)

            local nameLbl2 = mkLabel(row, opts.Title or "Slider", 13, T.TEXT)
            nameLbl2.Size     = UDim2.new(1,-60,0,20)
            nameLbl2.Position = UDim2.new(0,0,0,6)

            local valLbl = mkLabel(row, tostring(val), 12, T.ACCENT, Enum.TextXAlignment.Right)
            valLbl.Size     = UDim2.new(0,55,0,20)
            valLbl.Position = UDim2.new(1,-55,0,6)
            valLbl.Font     = Enum.Font.GothamBold

            local trackBG = mkFrame(row, UDim2.new(1,0,0,5), UDim2.new(0,0,0,36), T.BG)
            corner(trackBG, 3)
            local fill = mkFrame(trackBG, UDim2.new((val-min)/(max-min),0,1,0), nil, T.ACCENT)
            corner(fill, 3)
            local thumb = mkFrame(trackBG, UDim2.new(0,13,0,13), UDim2.new((val-min)/(max-min), -6, 0.5,-6), Color3.new(1,1,1))
            corner(thumb, 7)
            local thumbStroke = mkStroke(thumb, T.ACCENT, 2, 0)

            -- Update slider colors when accent changes
            onThemeChange(function()
                tw(fill, {BackgroundColor3 = T.ACCENT})
                tw(valLbl, {TextColor3 = T.ACCENT})
                if thumbStroke then tw(thumbStroke, {Color = T.ACCENT}) end
            end)

            local mouse   = game.Players.LocalPlayer:GetMouse()
            local sliding = false

            local function updateSlider(mx)
                local abs = trackBG.AbsolutePosition.X
                local sz  = trackBG.AbsoluteSize.X
                local pct = math.clamp((mx - abs) / sz, 0, 1)
                val = prec
                    and tonumber(string.format("%.1f", min + (max-min)*pct))
                    or  math.floor(min + (max-min)*pct + 0.5)
                local snapPct = (val-min)/(max-min)
                tw(fill,  {Size = UDim2.new(snapPct,0,1,0)}, 0.07)
                tw(thumb, {Position = UDim2.new(snapPct,-6,0.5,-6)}, 0.07)
                valLbl.Text = tostring(val)
                pcall(cb, val)
            end

            local btn2 = Instance.new("TextButton")
            btn2.Size = UDim2.new(1,0,1,0); btn2.BackgroundTransparency=1; btn2.Text=""
            btn2.Parent = trackBG
            btn2.MouseButton1Down:Connect(function() sliding = true; updateSlider(mouse.X) end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
            end)
            RunService.Heartbeat:Connect(function()
                if sliding then updateSlider(mouse.X) end
            end)

            local sliderObj = {
                Set = function(_,v)
                    val = math.clamp(v, min, max)
                    local pct = (val-min)/(max-min)
                    tw(fill,  {Size = UDim2.new(pct,0,1,0)}, 0.18)
                    tw(thumb, {Position = UDim2.new(pct,-6,0.5,-6)}, 0.18)
                    valLbl.Text = tostring(val); pcall(cb,val)
                end,
                Get = function(_) return val end,
            }
            if opts.Flag then registerConfigFlag(opts.Flag, sliderObj) end
            return sliderObj
        end

        function secObj:AddDropdown(opts, cb)
            opts = opts or {}
            local list = opts.List    or {}
            local sel  = opts.Default or (list[1])
            cb = cb or function() end

            local CLOSED_H = 76
            local row = mkFrame(card, UDim2.new(1,0,0,CLOSED_H), nil, T.BG3)
            registerFeature(opts.Title or "Dropdown", row)
            corner(row, 7)
            pad(row, 0, 0, 12, 12)

            local nameLbl2 = mkLabel(row, opts.Title or "Dropdown", 13, T.TEXT)
            nameLbl2.Size     = UDim2.new(1,0,0,18)
            nameLbl2.Position = UDim2.new(0,0,0,3)

            local selBar = mkFrame(row, UDim2.new(1,0,0,24), UDim2.new(0,0,0,28), T.BG4)
            corner(selBar, 6)
            mkStroke(selBar, T.HINT, 1, 0.4)

            local selLbl = mkLabel(selBar, tostring(sel or "Select…"), 12, T.TEXT)
            selLbl.Position = UDim2.new(0,10,0,0)
            selLbl.Size     = UDim2.new(1,-34,1,0)

            local chevHolder = Instance.new("Frame")
            chevHolder.Size = UDim2.new(0, 20, 0, 20)
            chevHolder.Position = UDim2.new(1, -24, 0.5, -10)
            chevHolder.BackgroundTransparency = 1
            chevHolder.Parent = selBar
            local chevIcon = mkChevronIcon(chevHolder, 16, T.SUBTEXT)

            local optFrame = mkFrame(row, UDim2.new(1,0,0,0), UDim2.new(0,0,0,63), T.BG4)
            corner(optFrame, 7)
            mkStroke(optFrame, T.HINT, 1, 0.4)
            optFrame.ClipsDescendants = true
            optFrame.Visible = false
            optFrame.ZIndex  = 8

            -- ScrollingFrame for scrollable dropdown
            local scrollFrame = Instance.new("ScrollingFrame")
            scrollFrame.Size = UDim2.new(1, 0, 1, 0)
            scrollFrame.Position = UDim2.new(0, 0, 0, 0)
            scrollFrame.BackgroundTransparency = 1
            scrollFrame.BorderSizePixel = 0
            scrollFrame.ScrollBarThickness = 3
            scrollFrame.ScrollBarImageColor3 = T.SUBTEXT
            scrollFrame.ScrollBarImageTransparency = 0.3
            scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
            scrollFrame.Parent = optFrame

            local optList = mkList(scrollFrame, 6)
            pad(scrollFrame, 4, 4, 4, 4)

            local totalOptH = 0
            local selectedOpt = nil -- track the selected option button
            for _, item in ipairs(list) do
                local opt = Instance.new("TextButton")
                opt.Size                 = UDim2.new(1,0,0,28)
                opt.BackgroundColor3     = T.BG4
                opt.BackgroundTransparency = 1
                opt.Text                 = ""
                opt.BorderSizePixel      = 0
                opt.Parent               = scrollFrame
                corner(opt, 5)

                local optLbl = mkLabel(opt, tostring(item), 13, item == sel and T.ACCENT or T.TEXT)
                optLbl.Position = UDim2.new(0,8,0,0)

                local dot = mkFrame(opt, UDim2.new(0,4,0,4), UDim2.new(0,0,0.5,-2), item==sel and T.ACCENT or Color3.new(0,0,0))
                dot.BackgroundTransparency = item==sel and 0 or 1
                corner(dot, 2)

                if item == sel then selectedOpt = opt end

                opt.MouseEnter:Connect(function()
                    tw(opt, {BackgroundTransparency=0, BackgroundColor3=T.BG3})
                end)
                opt.MouseLeave:Connect(function()
                    tw(opt, {BackgroundTransparency=1})
                end)
                opt.MouseButton1Click:Connect(function()
                    sel = item
                    selectedOpt = opt
                    selLbl.Text = tostring(item)
                    for _, child in ipairs(scrollFrame:GetChildren()) do
                        if child:IsA("TextButton") then
                            local cl = child:FindFirstChild("TextLabel")
                            local cd = child:FindFirstChildOfClass("Frame")
                            if cl then tw(cl, {TextColor3 = child==opt and T.ACCENT or T.TEXT}) end
                            if cd then
                                cd.BackgroundTransparency = child==opt and 0 or 1
                                cd.BackgroundColor3 = T.ACCENT
                            end
                        end
                    end
                    open = false
                    tw(optFrame, {Size=UDim2.new(1,0,0,0)}, 0.22, Enum.EasingStyle.Quint)
                    tw(row, {Size=UDim2.new(1,0,0,CLOSED_H)}, 0.22, Enum.EasingStyle.Quint)
                    tw(chevHolder, {Rotation=0}, 0.2, Enum.EasingStyle.Quint)
                    task.delay(0.23, function()
                        optFrame.Visible = false
                    end)
                    pcall(cb, item)
                end)
                totalOptH = totalOptH + 30
            end

            local open = false
            local OPEN_H = CLOSED_H + math.min(totalOptH + 12, 160) + 4

            local clickArea = Instance.new("TextButton")
            clickArea.Size = UDim2.new(1,0,0,CLOSED_H)
            clickArea.BackgroundTransparency = 1
            clickArea.Text = ""
            clickArea.Parent = row

            clickArea.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    optFrame.Visible = true
                    optFrame.Size = UDim2.new(1,0,0,0)
                    tw(row,      {Size=UDim2.new(1,0,0,OPEN_H)},  0.25, Enum.EasingStyle.Quint)
                    tw(optFrame, {Size=UDim2.new(1,0,0,math.min(totalOptH+12,160))}, 0.25, Enum.EasingStyle.Quint)
                    tw(chevHolder,  {Rotation=180}, 0.2)
                else
                    tw(optFrame, {Size=UDim2.new(1,0,0,0)}, 0.22, Enum.EasingStyle.Quint)
                    tw(row,      {Size=UDim2.new(1,0,0,CLOSED_H)}, 0.22, Enum.EasingStyle.Quint)
                    tw(chevHolder,  {Rotation=0}, 0.2, Enum.EasingStyle.Quint)
                    task.delay(0.23, function()
                        optFrame.Visible = false
                    end)
                end
            end)

            onThemeChange(function()
                for _, child in ipairs(scrollFrame:GetChildren()) do
                    if child:IsA("TextButton") then
                        local cl = child:FindFirstChild("TextLabel")
                        local cd = child:FindFirstChildOfClass("Frame")
                        local isSel = (child == selectedOpt)
                        if cl then tw(cl, {TextColor3 = isSel and T.ACCENT or T.TEXT}) end
                        if cd then
                            cd.BackgroundTransparency = isSel and 0 or 1
                            if isSel then tw(cd, {BackgroundColor3 = T.ACCENT}) end
                        end
                    end
                end
            end)

            local dropdownObj = {
                Set = function(_, v)
                    sel = v
                    selLbl.Text = tostring(v)
                    for _, child in ipairs(scrollFrame:GetChildren()) do
                        if child:IsA("TextButton") then
                            local cl = child:FindFirstChild("TextLabel")
                            local cd = child:FindFirstChildOfClass("Frame")
                            local isSel = cl and cl.Text == tostring(v)
                            if cl then cl.TextColor3 = isSel and T.ACCENT or T.TEXT end
                            if cd then
                                cd.BackgroundTransparency = isSel and 0 or 1
                                cd.BackgroundColor3 = T.ACCENT
                            end
                            if isSel then selectedOpt = child end
                        end
                    end
                    pcall(cb, v)
                end,
                Get = function(_) return sel end,
            }
            if opts.Flag then registerConfigFlag(opts.Flag, dropdownObj) end
            return dropdownObj
        end

