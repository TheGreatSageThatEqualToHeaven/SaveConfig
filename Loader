    local function normalizeConfigName(name)
        if type(name) ~= "string" then return "" end
        name = name:gsub("%.json$", "")
        name = name:gsub("^%s+", ""):gsub("%s+$", "")
        return name
    end

    -- Helper: ensure folder exists
    local function ensureFolder(folder)
