                modeBtn.Font = Enum.Font.GothamMedium
                modeBtn.TextSize = 12
                modeBtn.TextColor3 = T.ACCENT
                modeBtn.Text = bindMode
                modeBtn.BorderSizePixel = 0
                modeBtn.ZIndex = 201
                modeBtn.Parent = p
                corner(modeBtn, 6)
                mkStroke(modeBtn, T.HINT, 1, 0.4)

                modeBtn.Activated:Connect(function()
                    bindMode = bindMode == "Toggle" and "Hold" or "Toggle"
                    modeBtn.Text = bindMode
                end)

                onThemeChange(function()
                    if not popup or not popup.Parent then return end
                    tw(p, {BackgroundColor3 = T.BG}, 0.12)
                    if popupStroke then tw(popupStroke, {Color = T.SEP}, 0.12) end
                    tw(titleBar, {BackgroundColor3 = T.BG2}, 0.12)
                    tw(titleFill, {BackgroundColor3 = T.BG2}, 0.12)
                    tw(titleLbl, {TextColor3 = T.TEXT}, 0.12)
                    tw(popupPill, {BackgroundColor3 = T.ACCENT}, 0.12)
                    tw(closeBtn, {BackgroundColor3 = T.BG3}, 0.12)
                    tw(kbLbl, {TextColor3 = T.SUBTEXT}, 0.12)
                    tw(bindBtn, {BackgroundColor3 = T.BG4, TextColor3 = T.ACCENT}, 0.12)
                    tw(modeLbl, {TextColor3 = T.SUBTEXT}, 0.12)
                    tw(modeBtn, {BackgroundColor3 = T.BG4, TextColor3 = T.ACCENT}, 0.12)
                    if gearBtn and gearBtn.Parent then
                        tw(gearBtn, {BackgroundColor3 = T.BG4, ImageColor3 = T.SUBTEXT}, 0.12)
                    end
                end)

                -- Dragging (smooth lerp)
                local dragging, dragStart, startPos
                local popupDragTarget = nil
                titleBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        dragStart = input.Position
                        startPos = p.Position
                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then dragging = false end
                        end)
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local delta = input.Position - dragStart
                        popupDragTarget = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                    end
                end)
                RunService.Heartbeat:Connect(function()
                    if dragging and popupDragTarget then
                        local cur = p.Position
                        local lerpAmt = math.clamp(dragSmoothness, 0.05, 1)
                        local newX = cur.X.Offset + (popupDragTarget.X.Offset - cur.X.Offset) * lerpAmt
                        local newY = cur.Y.Offset + (popupDragTarget.Y.Offset - cur.Y.Offset) * lerpAmt
                        p.Position = UDim2.new(cur.X.Scale, newX, cur.Y.Scale, newY)
                    end
                end)

                -- Cleanup on popup destroy
                p.Destroying:Connect(function()
                    if inputConn then inputConn:Disconnect() end
                end)
            end

            gearBtn.Activated:Connect(function() openPopup() end)

            -- Input handling for keybind execution
            UserInputService.InputBegan:Connect(function(input, gp)
                if gp or not boundKey then return end
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == boundKey then
                    if bindMode == "Toggle" then
                        setStateFn(not getStateFn())
                    elseif bindMode == "Hold" then
                        setStateFn(true)
                    end
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if not boundKey then return end
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == boundKey then
                    if bindMode == "Hold" then
                        setStateFn(false)
                    end
                end
            end)

            onThemeChange(function()
                gearBtn.ImageColor3 = T.SUBTEXT
                gearBtn.BackgroundColor3 = T.BG4
            end)

            return gearBtn
        end

