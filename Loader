                huePin.ZIndex = 204
                corner(huePin, 4)
                mkStroke(huePin, Color3.new(1,1,1), 2, 0)

                -- Hex/RGB display
                local hexLabel = mkLabel(contentArea, "HEX", 9, T.SUBTEXT)
                hexLabel.Size = UDim2.new(1, 0, 0, 12)
                hexLabel.Position = UDim2.new(0, 0, 0, SV_SIZE + 6)
                hexLabel.Font = Enum.Font.GothamBold
                hexLabel.ZIndex = 201

                local r2 = math.round(currentColor.R * 255)
                local g2 = math.round(currentColor.G * 255)
                local b2 = math.round(currentColor.B * 255)

                local hexVal = mkLabel(contentArea, string.format("#%02X%02X%02X", r2, g2, b2), 12, T.TEXT)
                hexVal.Size = UDim2.new(0, 80, 0, 14)
                hexVal.Position = UDim2.new(0, 0, 0, SV_SIZE + 18)
                hexVal.Font = Enum.Font.GothamBold
                hexVal.ZIndex = 201

                local rgbVal = mkLabel(contentArea, string.format("RGB: %d, %d, %d", r2, g2, b2), 11, T.SUBTEXT)
                rgbVal.Size = UDim2.new(0, 80, 0, 14)
                rgbVal.Position = UDim2.new(0, 72, 0, SV_SIZE + 18)
                rgbVal.ZIndex = 201

                local function updatePickerColor()
                    currentColor = Color3.fromHSV(cpH, cpS, cpV)
                    tw(swatchBtn, {BackgroundColor3 = currentColor}, 0.1)
                    tw(svFrame, {BackgroundColor3 = Color3.fromHSV(cpH, 1, 1)}, 0.1)
                    tw(svPin, {Position = UDim2.new(cpS, -7, 1-cpV, -7), BackgroundColor3 = currentColor}, 0.08)
                    tw(huePin, {Position = UDim2.new(-0.1, 0, cpH, -3), BackgroundColor3 = Color3.fromHSV(cpH, 1, 1)}, 0.08)

                    local cr = math.round(currentColor.R * 255)
                    local cg = math.round(currentColor.G * 255)
                    local cb = math.round(currentColor.B * 255)
                    hexVal.Text = string.format("#%02X%02X%02X", cr, cg, cb)
                    rgbVal.Text = string.format("RGB: %d, %d, %d", cr, cg, cb)

                    pcall(colorChangedCb, currentColor)
                end

                -- SV drag
                local mouse = game.Players.LocalPlayer:GetMouse()
                local draggingSV = false
                local draggingHue = false

                local svBtn = Instance.new("TextButton")
                svBtn.Size = UDim2.new(1,0,1,0)
                svBtn.BackgroundTransparency = 1
                svBtn.Text = ""
                svBtn.ZIndex = 205
                svBtn.Parent = svFrame
                svBtn.MouseButton1Down:Connect(function() draggingSV = true end)

                local hueBtn = Instance.new("TextButton")
                hueBtn.Size = UDim2.new(1,0,1,0)
                hueBtn.BackgroundTransparency = 1
                hueBtn.Text = ""
                hueBtn.ZIndex = 205
                hueBtn.Parent = hueBar
                hueBtn.MouseButton1Down:Connect(function() draggingHue = true end)

                local inputEndedConn = UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSV = false
                        draggingHue = false
                    end
                end)

                local heartbeatConn = RunService.Heartbeat:Connect(function()
                    if draggingSV then
                        local absX = svFrame.AbsolutePosition.X
                        local absY = svFrame.AbsolutePosition.Y
                        local szX  = svFrame.AbsoluteSize.X
                        local szY  = svFrame.AbsoluteSize.Y
                        cpS = math.clamp((mouse.X - absX) / szX, 0, 1)
                        cpV = 1 - math.clamp((mouse.Y - absY) / szY, 0, 1)
                        updatePickerColor()
                    elseif draggingHue then
                        local absY = hueBar.AbsolutePosition.Y
                        local szY  = hueBar.AbsoluteSize.Y
                        cpH = math.clamp((mouse.Y - absY) / szY, 0, 1)
                        updatePickerColor()
                    end
                end)

                -- Cleanup connections when popup destroyed
                p.Destroying:Connect(function()
                    if inputEndedConn then inputEndedConn:Disconnect() end
                    if heartbeatConn then heartbeatConn:Disconnect() end
                end)
            end

            swatchBtn.Activated:Connect(function() openColorPopup() end)

            onThemeChange(function()
                -- swatch color stays as user-picked
                -- Update accent pill if popup is open
                if cpPopup and cpPopup.Parent then
                    local pill = cpPopup:FindFirstChild("PopupPill", true)
                    if pill then tw(pill, {BackgroundColor3 = T.ACCENT}, 0.12) end
                end
            end)

            local cpObj = {
                SetColor = function(_, col)
                    cpH, cpS, cpV = col:ToHSV()
                    currentColor = col
                    swatchBtn.BackgroundColor3 = col
                    pcall(colorChangedCb, col)
                end,
                GetColor = function(_) return currentColor end,
                _swatchBtn = swatchBtn,
            }

            return swatchBtn, cpObj
        end

