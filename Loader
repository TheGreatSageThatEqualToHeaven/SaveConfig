        -----------------------------------------------------------------
        function secObj:AddMultiDropdown(opts, cb)
            opts = opts or {}
            local list = opts.List or {}
            local selected = {}
            cb = cb or function() end

            if opts.Default then
                for _, v in ipairs(opts.Default) do
                    selected[v] = true
                end
            end

            local CLOSED_H = 76
            local row = mkFrame(card, UDim2.new(1,0,0,CLOSED_H), nil, T.BG3)
            registerFeature(opts.Title or "Multi Dropdown", row)
            row.ClipsDescendants = true
            corner(row, 7)
            pad(row, 0, 0, 12, 12)

            local nameLbl2 = mkLabel(row, opts.Title or "Multi Select", 13, T.TEXT)
            nameLbl2.Size     = UDim2.new(1,0,0,18)
            nameLbl2.Position = UDim2.new(0,0,0,3)

            local selBar = mkFrame(row, UDim2.new(1,0,0,24), UDim2.new(0,0,0,28), T.BG4)
            corner(selBar, 6)
            mkStroke(selBar, T.HINT, 1, 0.4)

            local function getDisplayText()
                local names = {}
                for _, item in ipairs(list) do
                    if selected[item] then table.insert(names, tostring(item)) end
                end
                if #names == 0 then return "None selected" end
                local txt = table.concat(names, ", ")
                if #txt > 30 then txt = string.sub(txt, 1, 27) .. "..." end
                return txt
            end

            local selLbl = mkLabel(selBar, getDisplayText(), 12, T.TEXT)
            selLbl.Position = UDim2.new(0,10,0,0)
            selLbl.Size     = UDim2.new(1,-34,1,0)

            local chevHolder = Instance.new("Frame")
            chevHolder.Size = UDim2.new(0, 20, 0, 20)
            chevHolder.Position = UDim2.new(1, -24, 0.5, -10)
            chevHolder.BackgroundTransparency = 1
            chevHolder.Parent = selBar
            mkChevronIcon(chevHolder, 16, T.SUBTEXT)

            local optFrame = mkFrame(row, UDim2.new(1,0,0,0), UDim2.new(0,0,0,63), T.BG4)
            corner(optFrame, 7)
            mkStroke(optFrame, T.HINT, 1, 0.4)
            optFrame.ClipsDescendants = true
            optFrame.Visible = false
            optFrame.ZIndex  = 8

            -- ScrollingFrame for scrollable multi-dropdown
            local scrollFrame = Instance.new("ScrollingFrame")
            scrollFrame.Size = UDim2.new(1, 0, 1, 0)
            scrollFrame.Position = UDim2.new(0, 0, 0, 0)
            scrollFrame.BackgroundTransparency = 1
            scrollFrame.BorderSizePixel = 0
            scrollFrame.ScrollBarThickness = 3
            scrollFrame.ScrollBarImageColor3 = T.SUBTEXT
            scrollFrame.ScrollBarImageTransparency = 0.3
            scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
            scrollFrame.Parent = optFrame

            local optList = mkList(scrollFrame, 6)
            pad(scrollFrame, 4, 4, 4, 4)

            local totalOptH = 0
            local checkboxes = {}

            for _, item in ipairs(list) do
                local opt = Instance.new("TextButton")
                opt.Size                 = UDim2.new(1,0,0,28)
                opt.BackgroundColor3     = T.BG4
                opt.BackgroundTransparency = 1
                opt.Text                 = ""
                opt.BorderSizePixel      = 0
                opt.Parent               = scrollFrame
                corner(opt, 5)

                local chk = mkFrame(opt, UDim2.new(0,14,0,14), UDim2.new(0,2,0.5,-7), selected[item] and T.ACCENT or T.OFF)
                corner(chk, 4)
                mkStroke(chk, T.HINT, 1, 0.3)

                local checkMark = Instance.new("TextLabel")
                checkMark.Size = UDim2.new(1,0,1,0)
                checkMark.BackgroundTransparency = 1
                checkMark.Text = "✓"
                checkMark.TextColor3 = Color3.new(1,1,1)
                checkMark.TextSize = 11
                checkMark.Font = Enum.Font.GothamBold
                checkMark.TextTransparency = selected[item] and 0 or 1
                checkMark.Parent = chk

                local optLbl = mkLabel(opt, tostring(item), 13, selected[item] and T.ACCENT or T.TEXT)
                optLbl.Position = UDim2.new(0,22,0,0)

                checkboxes[item] = { chk = chk, lbl = optLbl }

                opt.MouseEnter:Connect(function()
                    tw(opt, {BackgroundTransparency=0, BackgroundColor3=T.BG3})
                end)
                opt.MouseLeave:Connect(function()
                    tw(opt, {BackgroundTransparency=1})
                end)
                opt.MouseButton1Click:Connect(function()
                    selected[item] = not selected[item]
                    local isOn = selected[item]
                    tw(chk, {BackgroundColor3 = isOn and T.ACCENT or T.OFF}, 0.15)
                    tw(checkMark, {TextTransparency = isOn and 0 or 1}, 0.15)
                    tw(optLbl, {TextColor3 = isOn and T.ACCENT or T.TEXT}, 0.15)
                    selLbl.Text = getDisplayText()

                    local result = {}
                    for _, v in ipairs(list) do
                        if selected[v] then table.insert(result, v) end
                    end
                    pcall(cb, result)
                end)
                totalOptH = totalOptH + 30
            end

            local open = false
            local OPEN_H = CLOSED_H + math.min(totalOptH + 12, 160) + 4

            local clickArea = Instance.new("TextButton")
            clickArea.Size = UDim2.new(1,0,0,CLOSED_H)
            clickArea.BackgroundTransparency = 1
            clickArea.Text = ""
            clickArea.Parent = row

            clickArea.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    optFrame.Visible = true
                    optFrame.Size = UDim2.new(1,0,0,0)
                    tw(row,      {Size=UDim2.new(1,0,0,OPEN_H)},  0.25, Enum.EasingStyle.Quint)
                    tw(optFrame, {Size=UDim2.new(1,0,0,math.min(totalOptH+12,160))}, 0.25, Enum.EasingStyle.Quint)
                    tw(chevHolder,  {Rotation=180}, 0.2)
                else
                    tw(optFrame, {Size=UDim2.new(1,0,0,0)}, 0.22, Enum.EasingStyle.Quint)
                    tw(row,      {Size=UDim2.new(1,0,0,CLOSED_H)}, 0.22, Enum.EasingStyle.Quint)
                    tw(chevHolder,  {Rotation=0}, 0.2, Enum.EasingStyle.Quint)
                    task.delay(0.23, function()
                        optFrame.Visible = false
                    end)
                end
            end)

            onThemeChange(function()
                for _, item in ipairs(list) do
                    local c = checkboxes[item]
                    if c then
                        local isOn = selected[item] or false
                        if isOn then
                            tw(c.chk, {BackgroundColor3 = T.ACCENT})
                            tw(c.lbl, {TextColor3 = T.ACCENT})
                        end
                    end
                end
            end)

            local multiDropdownObj = {
                Set = function(_, vals)
                    selected = {}
                    for _, v in ipairs(vals) do selected[v] = true end
                    selLbl.Text = getDisplayText()
                    for _, item in ipairs(list) do
                        local c = checkboxes[item]
                        if c then
                            local isOn = selected[item] or false
                            c.chk.BackgroundColor3 = isOn and T.ACCENT or T.OFF
                            c.lbl.TextColor3 = isOn and T.ACCENT or T.TEXT
                        end
                    end
                    local result = {}
                    for _, v in ipairs(list) do
                        if selected[v] then table.insert(result, v) end
                    end
                    pcall(cb, result)
                end,
                Get = function(_)
                    local result = {}
                    for _, v in ipairs(list) do
                        if selected[v] then table.insert(result, v) end
                    end
                    return result
                end,
            }
            if opts.Flag then registerConfigFlag(opts.Flag, multiDropdownObj) end
            return multiDropdownObj
        end

