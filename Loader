    local function doSave()
        local name = normalizeConfigName(configNameBox.Text)
        if name == "" then return end
        local ok = saveCurrentConfig(name)
        if ok then
            hiddenDeletedConfigs[name] = nil
            knownSavedConfigs[name] = true
            saveManifest()
            configNameBox.Text = name
            refreshConfigList()
        end
        if autoloadState then
            setAutoloadName(name)
            autoloadState = true
            updateAutoloadVisual()
            refreshConfigList()
        end
        if self.Notify then
            self:Notify({
                Title = "Config",
                Desc = ok and ("Saved: " .. name) or ("Save failed: " .. name),
                Duration = 3,
                Kind = ok and "success" or "error"
            })
        end
    end

