-- Keybind List Panel
---------------------------------------------------------------------------
function SimpleUI:ShowKeybindList(options)
    options = options or {}
    local sg = self._sg
    if not sg then return end

    -- Prevent duplicates
    local existing = sg:FindFirstChild("KeybindListPanel")
    if existing then existing:Destroy() end

    local registry = self._keybindRegistry or {}

    local ROW_H = 28
    local HEADER_H = 36
    local PADDING = 8
    local WIDTH = 280
    local MAX_ROWS = 15
    local visibleRows = math.min(#registry, MAX_ROWS)
    local contentH = visibleRows * (ROW_H + 4) + PADDING * 2
    local totalH = HEADER_H + contentH + 4

    -- Main panel position (custom or centered)
    local screenSize = sg.AbsoluteSize
    local px = options.X or 10
    local py = options.Y or 550

    local panel = mkFrame(sg, UDim2.new(0, WIDTH, 0, totalH), UDim2.new(0, px, 0, py), T.BG)
    panel.Name = "KeybindListPanel"
    panel.ZIndex = 200
    panel.Active = true
    panel.BackgroundTransparency = 1
    panel.ClipsDescendants = true
    corner(panel, 10)
    local panelStroke = mkStroke(panel, T.SEP, 1, 0)

    -- Shadow
    local shadow = Instance.new("ImageLabel")
    shadow.Size = UDim2.new(1, 24, 1, 24)
    shadow.Position = UDim2.new(0, -12, 0, -12)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://6015897843"
    shadow.ImageColor3 = Color3.new(0, 0, 0)
    shadow.ImageTransparency = 0.85
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(49, 49, 450, 450)
    shadow.ZIndex = 199
    shadow.Parent = panel

    tw(panel, {BackgroundTransparency = 0}, 0.15)

    -- Title bar
    local titleBar = mkFrame(panel, UDim2.new(1, 0, 0, HEADER_H), UDim2.new(0, 0, 0, 0), T.BG2)
    titleBar.ZIndex = 201
    titleBar.Active = true
    corner(titleBar, 10)

    local titleFill = mkFrame(panel, UDim2.new(1, 0, 0, 10), UDim2.new(0, 0, 0, HEADER_H - 10), T.BG2)
    titleFill.ZIndex = 200

    local pill = mkFrame(titleBar, UDim2.new(0, 3, 0, 18), UDim2.new(0, 8, 0.5, -9), T.ACCENT)
    pill.ZIndex = 202
    corner(pill, 3)

    local titleLbl = mkLabel(titleBar, "Keybinds", 13, T.TEXT)
    titleLbl.Size = UDim2.new(1, -40, 1, 0)
    titleLbl.Position = UDim2.new(0, 18, 0, 0)
    titleLbl.ZIndex = 202
    titleLbl.Font = Enum.Font.GothamBold

    -- Close button (right side, matching keybind/colorpicker popups exactly)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 22, 0, 22)
    closeBtn.Position = UDim2.new(1, -28, 0, 5)
    closeBtn.BackgroundColor3 = T.BG3
    closeBtn.Text = ""
    closeBtn.BorderSizePixel = 0
    closeBtn.ZIndex = 202
    closeBtn.Parent = titleBar
    corner(closeBtn, 7)
    local kbListCloseIcon = mkCloseIcon(closeBtn, 10, T.SUBTEXT)

    closeBtn.MouseEnter:Connect(function()
        tw(closeBtn, {BackgroundColor3 = T.BG4}, 0.15)
        for _, child in ipairs(kbListCloseIcon:GetChildren()) do
            if child:IsA("Frame") then tw(child, {BackgroundColor3 = T.TEXT}, 0.15) end
        end
    end)
    closeBtn.MouseLeave:Connect(function()
        tw(closeBtn, {BackgroundColor3 = T.BG3}, 0.15)
        for _, child in ipairs(kbListCloseIcon:GetChildren()) do
            if child:IsA("Frame") then tw(child, {BackgroundColor3 = T.SUBTEXT}, 0.15) end
        end
    end)

    local function closePanel()
        tw(panel, {BackgroundTransparency = 1}, 0.15)
        for _, c in ipairs(panel:GetDescendants()) do
            if c:IsA("GuiObject") then tw(c, {BackgroundTransparency = 1}, 0.12) end
            if c:IsA("TextLabel") or c:IsA("TextButton") then tw(c, {TextTransparency = 1}, 0.12) end
            if c:IsA("ImageLabel") or c:IsA("ImageButton") then tw(c, {ImageTransparency = 1}, 0.12) end
            if c:IsA("UIStroke") then tw(c, {Transparency = 1}, 0.12) end
        end
        task.delay(0.18, function()
            if panel then panel:Destroy() end
        end)
    end

    closeBtn.MouseButton1Click:Connect(closePanel)


    -- Scrolling content area
    local scrollArea = Instance.new("ScrollingFrame")
    scrollArea.Size = UDim2.new(1, -PADDING * 2, 0, contentH)
    scrollArea.Position = UDim2.new(0, PADDING, 0, HEADER_H + 2)
    scrollArea.BackgroundTransparency = 1
    scrollArea.BorderSizePixel = 0
    scrollArea.ScrollBarThickness = 3
    scrollArea.ScrollBarImageColor3 = T.ACCENT
    scrollArea.CanvasSize = UDim2.new(0, 0, 0, #registry * (ROW_H + 4))
    scrollArea.ZIndex = 201
    scrollArea.Parent = panel

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = scrollArea

    -- Populate rows
    for i, entry in ipairs(registry) do
        local rowFrame = mkFrame(scrollArea, UDim2.new(1, 0, 0, ROW_H), nil, T.BG3)
        rowFrame.ZIndex = 202
        rowFrame.LayoutOrder = i
        corner(rowFrame, 5)

        -- Checkbox indicator (visual only)
        local chkBox = mkFrame(rowFrame, UDim2.new(0, 16, 0, 16), UDim2.new(0, 6, 0.5, -8), T.OFF)
        chkBox.ZIndex = 203
        corner(chkBox, 3)
        mkStroke(chkBox, T.HINT, 1, 0.3)

        local checkMark = Instance.new("TextLabel")
        checkMark.Size = UDim2.new(1, 0, 1, 0)
        checkMark.BackgroundTransparency = 1
        checkMark.Text = "✓"
        checkMark.TextColor3 = Color3.new(1, 1, 1)
        checkMark.TextSize = 12
        checkMark.Font = Enum.Font.GothamBold
        checkMark.ZIndex = 204
        checkMark.Parent = chkBox

        -- Key display
        local keyStr = entry.getKey() and entry.getKey().Name or "None"
        local keyLbl = mkLabel(rowFrame, "[" .. keyStr .. "]", 11, T.SUBTEXT)
        keyLbl.Size = UDim2.new(0, 36, 1, 0)
        keyLbl.Position = UDim2.new(0, 26, 0, 0)
        keyLbl.ZIndex = 203
        keyLbl.TextXAlignment = Enum.TextXAlignment.Left

        -- Title
        local titleText = entry.title
        local nameLbl = mkLabel(rowFrame, titleText, 12, T.TEXT)
        nameLbl.Size = UDim2.new(1, -140, 1, 0)
        nameLbl.Position = UDim2.new(0, 64, 0, 0)
        nameLbl.ZIndex = 203
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

        -- Mode badge
        local modeStr = "(" .. entry.getMode() .. ")"
        local modeLbl = mkLabel(rowFrame, modeStr, 11, T.SUBTEXT)
        modeLbl.Size = UDim2.new(0, 60, 1, 0)
        modeLbl.Position = UDim2.new(1, -64, 0, 0)
        modeLbl.ZIndex = 203
        modeLbl.TextXAlignment = Enum.TextXAlignment.Right

        -- Update checkbox state visually
        local function updateRow()
            local isOn = false
            pcall(function() isOn = entry.getState() end)
            chkBox.BackgroundColor3 = isOn and T.ACCENT or T.OFF
            checkMark.TextTransparency = isOn and 0 or 1

            local k = entry.getKey()
            keyLbl.Text = "[" .. (k and k.Name or "None") .. "]"
            modeLbl.Text = "(" .. entry.getMode() .. ")"
        end
        updateRow()

        -- Live update every 0.5s
        task.spawn(function()
            while rowFrame and rowFrame.Parent do
                updateRow()
                task.wait(0.05)
            end
        end)
    end

    -- Empty state
    if #registry == 0 then
        local emptyLbl = mkLabel(scrollArea, "No keybinds configured", 12, T.SUBTEXT)
        emptyLbl.Size = UDim2.new(1, 0, 0, 40)
        emptyLbl.ZIndex = 203
    end

    -- Dragging (smooth lerp)
    local dragging, dragStart, startPos
    local panelDragTarget = nil
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = panel.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            panelDragTarget = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    RunService.Heartbeat:Connect(function()
        if dragging and panelDragTarget then
            local cur = panel.Position
            local lerpAmt = math.clamp(dragSmoothness, 0.05, 1)
            local newX = cur.X.Offset + (panelDragTarget.X.Offset - cur.X.Offset) * lerpAmt
            local newY = cur.Y.Offset + (panelDragTarget.Y.Offset - cur.Y.Offset) * lerpAmt
            panel.Position = UDim2.new(cur.X.Scale, newX, cur.Y.Scale, newY)
        end
    end)

    -- Theme support
    onThemeChange(function()
        if not panel or not panel.Parent then return end
        tw(panel, {BackgroundColor3 = T.BG}, 0.12)
        tw(panelStroke, {Color = T.SEP}, 0.12)
        tw(titleBar, {BackgroundColor3 = T.BG2}, 0.12)
        tw(titleFill, {BackgroundColor3 = T.BG2}, 0.12)
        tw(titleLbl, {TextColor3 = T.TEXT}, 0.12)
        tw(pill, {BackgroundColor3 = T.ACCENT}, 0.12)
        tw(closeBtn, {BackgroundColor3 = T.BG3}, 0.12)
    end)
end

