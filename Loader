    -- Logo / Icon ring
    local ringSize = 48
    local ring = Instance.new("Frame")
    ring.Size = UDim2.new(0, ringSize, 0, ringSize)
    ring.Position = UDim2.new(0.5, -ringSize/2, 0, 10)
    ring.BackgroundColor3 = T.ACCENT
    ring.BackgroundTransparency = 0.85
    ring.ZIndex = 502
    ring.Parent = center
    local ringCorner = Instance.new("UICorner")
    ringCorner.CornerRadius = UDim.new(1, 0)
    ringCorner.Parent = ring

    local ringStroke = Instance.new("UIStroke")
    ringStroke.Color = T.ACCENT
    ringStroke.Thickness = 2
    ringStroke.Transparency = 0
    ringStroke.Parent = ring

    -- Inner icon or letter
    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(1, 0, 1, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.ZIndex = 503
    iconLbl.Parent = ring
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.TextSize = 22
    iconLbl.TextColor3 = T.ACCENT
    iconLbl.Text = logo and "" or string.sub(loadTitle, 1, 1):upper()
    iconLbl.TextTransparency = 0

    if logo then
        local logoImg = Instance.new("ImageLabel")
        logoImg.Size = UDim2.new(0, 28, 0, 28)
        logoImg.Position = UDim2.new(0.5, -14, 0.5, -14)
        logoImg.BackgroundTransparency = 1
        logoImg.Image = "rbxassetid://" .. tostring(logo)
        logoImg.ImageColor3 = T.ACCENT
        logoImg.ZIndex = 503
        logoImg.Parent = ring
    end

    -- Title
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, 0, 0, 24)
    titleLbl.Position = UDim2.new(0, 0, 0, 68)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 18
    titleLbl.TextColor3 = T.TEXT
    titleLbl.Text = loadTitle
    titleLbl.TextTransparency = 1
    titleLbl.ZIndex = 502
    titleLbl.Parent = center

    -- Subtitle
    local subLbl = Instance.new("TextLabel")
    subLbl.Size = UDim2.new(1, 0, 0, 16)
    subLbl.Position = UDim2.new(0, 0, 0, 94)
    subLbl.BackgroundTransparency = 1
    subLbl.Font = Enum.Font.Gotham
    subLbl.TextSize = 11
    subLbl.TextColor3 = T.SUBTEXT
    subLbl.Text = loadSubtitle
    subLbl.TextTransparency = 1
    subLbl.ZIndex = 502
    subLbl.Parent = center

    -- Progress bar background
    local barBg = Instance.new("Frame")
    barBg.Size = UDim2.new(0.8, 0, 0, 4)
    barBg.Position = UDim2.new(0.1, 0, 0, 125)
    barBg.BackgroundColor3 = T.BG3
    barBg.ZIndex = 502
    barBg.Parent = center
    local barBgCorner = Instance.new("UICorner")
    barBgCorner.CornerRadius = UDim.new(1, 0)
    barBgCorner.Parent = barBg

    -- Progress bar fill
    local barFill = Instance.new("Frame")
    barFill.Size = UDim2.new(0, 0, 1, 0)
    barFill.BackgroundColor3 = T.ACCENT
    barFill.ZIndex = 503
    barFill.Parent = barBg
    local barFillCorner = Instance.new("UICorner")
    barFillCorner.CornerRadius = UDim.new(1, 0)
    barFillCorner.Parent = barFill

    -- Glow on progress bar
    local barGlow = Instance.new("Frame")
    barGlow.Size = UDim2.new(0, 0, 0, 10)
    barGlow.Position = UDim2.new(0, 0, 0.5, -5)
    barGlow.BackgroundColor3 = T.ACCENT
    barGlow.BackgroundTransparency = 0.7
    barGlow.ZIndex = 502
    barGlow.Parent = barBg
    local barGlowCorner = Instance.new("UICorner")
    barGlowCorner.CornerRadius = UDim.new(1, 0)
    barGlowCorner.Parent = barGlow

    -- Status text
    local statusLbl = Instance.new("TextLabel")
    statusLbl.Size = UDim2.new(1, 0, 0, 16)
    statusLbl.Position = UDim2.new(0, 0, 0, 140)
    statusLbl.BackgroundTransparency = 1
    statusLbl.Font = Enum.Font.Gotham
    statusLbl.TextSize = 10
    statusLbl.TextColor3 = T.HINT
    statusLbl.Text = ""
    statusLbl.TextTransparency = 1
    statusLbl.ZIndex = 502
    statusLbl.Parent = center

    -- Percentage text
    local pctLbl = Instance.new("TextLabel")
    pctLbl.Size = UDim2.new(1, 0, 0, 14)
    pctLbl.Position = UDim2.new(0, 0, 0, 158)
    pctLbl.BackgroundTransparency = 1
    pctLbl.Font = Enum.Font.GothamBold
    pctLbl.TextSize = 10
    pctLbl.TextColor3 = T.ACCENT
    pctLbl.Text = "0%"
    pctLbl.TextTransparency = 1
    pctLbl.ZIndex = 502
    pctLbl.Parent = center

    -- Animate intro
    task.spawn(function()
        -- Fade in panel with scale
        overlay.Size = UDim2.new(0, 0, 0, 0)
        overlay.Position = UDim2.new(0.5, 0, 0.5, 0)
        loadGlow.Size = UDim2.new(0, 0, 0, 0)
        loadGlow.Position = UDim2.new(0.5, 0, 0.5, 0)
        TweenService:Create(overlay, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, panelW, 0, panelH),
            Position = UDim2.new(0.5, -panelW/2, 0.5, -panelH/2)
        }):Play()
        TweenService:Create(loadGlow, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, panelW + 34, 0, panelH + 36),
            Position = UDim2.new(0.5, -panelW/2 - 17, 0.5, -panelH/2 - 19)
        }):Play()
        task.wait(0.3)

        -- Fade in ring with scale
        ring.Size = UDim2.new(0, 0, 0, 0)
        ring.Position = UDim2.new(0.5, 0, 0, 10 + ringSize/2)
        TweenService:Create(ring, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, ringSize, 0, ringSize),
            Position = UDim2.new(0.5, -ringSize/2, 0, 10)
        }):Play()
        task.wait(0.2)

        -- Fade in texts
        TweenService:Create(titleLbl, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        task.wait(0.15)
        TweenService:Create(subLbl, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        TweenService:Create(statusLbl, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        TweenService:Create(pctLbl, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        task.wait(0.15)

        -- Pulse ring animation (continuous gentle scale pulse)
        task.spawn(function()
            while ring and ring.Parent do
                TweenService:Create(ringStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    Transparency = 0.5
                }):Play()
                TweenService:Create(ring, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    BackgroundTransparency = 0.7
                }):Play()
                task.wait(0.8)
                TweenService:Create(ringStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    Transparency = 0
                }):Play()
                TweenService:Create(ring, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    BackgroundTransparency = 0.85
                }):Play()
                task.wait(0.8)
            end
        end)

        -- Progress animation with steps
        local stepDuration = duration / #steps
        for i, stepText in ipairs(steps) do
            -- Update status text with fade
            TweenService:Create(statusLbl, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
            task.wait(0.15)
            statusLbl.Text = stepText
            TweenService:Create(statusLbl, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()

            -- Animate progress bar
            local targetPct = i / #steps
            TweenService:Create(barFill, TweenInfo.new(stepDuration * 0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                Size = UDim2.new(targetPct, 0, 1, 0)
            }):Play()
            TweenService:Create(barGlow, TweenInfo.new(stepDuration * 0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                Size = UDim2.new(targetPct, 0, 0, 10)
            }):Play()

            -- Animate percentage counter
            local startPct = math.floor(((i - 1) / #steps) * 100)
            local endPct = math.floor(targetPct * 100)
            local counterTime = stepDuration * 0.8
            local counterStart = tick()
            while tick() - counterStart < counterTime do
                local alpha = math.min((tick() - counterStart) / counterTime, 1)
                local currentPct = math.floor(startPct + (endPct - startPct) * alpha)
                pctLbl.Text = currentPct .. "%"
                task.wait(0.03)
            end
            pctLbl.Text = endPct .. "%"

            task.wait(stepDuration * 0.2)
        end

        pctLbl.Text = "100%"
        task.wait(0.3)

        -- Success flash
        TweenService:Create(barFill, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = T.ON
        }):Play()
        TweenService:Create(barGlow, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = T.ON
        }):Play()
        statusLbl.Text = "\xe2\x9c\x93 Complete"
        statusLbl.TextColor3 = T.ON
        task.wait(0.6)

        -- Fade out loading panel
        TweenService:Create(overlay, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(loadGlow, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            ImageTransparency = 1
        }):Play()
        TweenService:Create(titleLbl, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        TweenService:Create(subLbl, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        TweenService:Create(statusLbl, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        TweenService:Create(pctLbl, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        TweenService:Create(ring, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        TweenService:Create(ringStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
        TweenService:Create(iconLbl, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        TweenService:Create(barBg, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        TweenService:Create(barFill, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        TweenService:Create(barGlow, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        task.wait(0.35)

        -- Remove overlay and glow, show main window
        overlay:Destroy()
        loadGlow:Destroy()
        win.Visible = true
        if glow then glow.Visible = true end

        -- Window entrance animation (scale from center)
        win.Size = UDim2.new(0, 0, 0, 0)
        win.Position = UDim2.new(0.5, 0, 0.5, 0)
        TweenService:Create(win, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 750, 0, 500),
            Position = UDim2.new(0.5, -375, 0.5, -250)
        }):Play()
        if glow then
            glow.Size = UDim2.new(0, 0, 0, 0)
            glow.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(glow, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 750 + 34, 0, 500 + 36),
                Position = UDim2.new(0.5, -375 - 17, 0.5, -250 - 19)
            }):Play()
        end
        task.wait(0.5)

        if onComplete then
            pcall(onComplete)
        end
    end)
end


return SimpleUI
