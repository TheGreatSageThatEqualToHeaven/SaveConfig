            corner(huePin, 4)
            mkStroke(huePin, Color3.new(1,1,1), 2, 0)
            huePin.ZIndex = 4

            -- Info panel (right of hue bar)
            local infoFrame = mkFrame(pickerArea, UDim2.new(1,-SV_SIZE-42,0,SV_SIZE), UDim2.new(0,SV_SIZE+42,0,0), Color3.new(0,0,0), 1)

            local hexLabel = mkLabel(infoFrame, "HEX", 10, T.SUBTEXT)
            hexLabel.Size = UDim2.new(1,0,0,12)
            hexLabel.Font = Enum.Font.GothamBold

            local hexVal = mkLabel(infoFrame, "", 13, T.TEXT)
            hexVal.Size = UDim2.new(1,0,0,16)
            hexVal.Position = UDim2.new(0,0,0,11)
            hexVal.Font = Enum.Font.GothamBold

            local rgbLabel = mkLabel(infoFrame, "RGB", 10, T.SUBTEXT)
            rgbLabel.Size = UDim2.new(1,0,0,12)
            rgbLabel.Position = UDim2.new(0,0,0,28)
            rgbLabel.Font = Enum.Font.GothamBold

            local rgbVal = mkLabel(infoFrame, "", 12, T.TEXT)
            rgbVal.Size = UDim2.new(1,0,0,16)
            rgbVal.Position = UDim2.new(0,0,0,39)


            local recentLabel = mkLabel(infoFrame, "Recent", 10, T.SUBTEXT)
            recentLabel.Size = UDim2.new(1,0,0,12)
            recentLabel.Position = UDim2.new(0,0,0,54)
            recentLabel.Font = Enum.Font.GothamBold

            local recentRow = mkFrame(infoFrame, UDim2.new(1,0,0,16), UDim2.new(0,0,0,65), Color3.new(0,0,0), 1)
            local recentColors = {}
            local MAX_RECENT = 6

            -- Color name helper based on hue/sat/val

            local function updateColor()
                local col = Color3.fromHSV(h, s, v)
                tw(swatch, {BackgroundColor3 = col}, 0.1)
                tw(svFrame, {BackgroundColor3 = Color3.fromHSV(h, 1, 1)}, 0.1)
                tw(svPin, {Position = UDim2.new(s, -7, 1-v, -7), BackgroundColor3 = col}, 0.08)
                tw(huePin, {Position = UDim2.new(-0.1, 0, h, -3), BackgroundColor3 = Color3.fromHSV(h, 1, 1)}, 0.08)

                local r2 = math.round(col.R * 255)
                local g2 = math.round(col.G * 255)
                local b2 = math.round(col.B * 255)
                hexVal.Text = string.format("#%02X%02X%02X", r2, g2, b2)
                rgbVal.Text = string.format("%d, %d, %d", r2, g2, b2)


                pcall(cb, col)
            end
            updateColor()

            local function addRecent(col)
                if #recentColors >= MAX_RECENT then
                    local oldest = table.remove(recentColors, 1)
                    if oldest then oldest:Destroy() end
                    -- Reposition remaining dots so they shift left
                    for i, dot in ipairs(recentColors) do
                        tw(dot, {Position = UDim2.new(0, (i-1) * 18, 0, 0)}, 0.2)
                    end
                end
                local dot = mkFrame(recentRow, UDim2.new(0,14,0,14), UDim2.new(0, #recentColors * 18, 0, 0), col)
                corner(dot, 4)
                dot.BackgroundTransparency = 1
                tw(dot, {BackgroundTransparency = 0}, 0.3)
                table.insert(recentColors, dot)

                local clickDot = Instance.new("TextButton")
                clickDot.Size = UDim2.new(1,0,1,0)
                clickDot.BackgroundTransparency = 1
                clickDot.Text = ""
                clickDot.Parent = dot
                clickDot.MouseButton1Click:Connect(function()
                    h, s, v = col:ToHSV()
                    updateColor()
                end)
            end

            local mouse = game.Players.LocalPlayer:GetMouse()
            local draggingSV = false
            local draggingHue = false

            local svBtn = Instance.new("TextButton")
            svBtn.Size = UDim2.new(1,0,1,0)
            svBtn.BackgroundTransparency = 1
            svBtn.Text = ""
            svBtn.ZIndex = 5
            svBtn.Parent = svFrame
            svBtn.MouseButton1Down:Connect(function() draggingSV = true end)

            local hueBtn = Instance.new("TextButton")
            hueBtn.Size = UDim2.new(1,0,1,0)
            hueBtn.BackgroundTransparency = 1
            hueBtn.Text = ""
            hueBtn.ZIndex = 5
            hueBtn.Parent = hueBar
            hueBtn.MouseButton1Down:Connect(function() draggingHue = true end)

            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    if draggingSV or draggingHue then
                        addRecent(Color3.fromHSV(h, s, v))
                    end
                    draggingSV = false
                    draggingHue = false
                end
            end)

            RunService.Heartbeat:Connect(function()
                if draggingSV then
                    local absX = svFrame.AbsolutePosition.X
                    local absY = svFrame.AbsolutePosition.Y
                    local szX  = svFrame.AbsoluteSize.X
                    local szY  = svFrame.AbsoluteSize.Y
                    s = math.clamp((mouse.X - absX) / szX, 0, 1)
                    v = 1 - math.clamp((mouse.Y - absY) / szY, 0, 1)
                    updateColor()
                elseif draggingHue then
                    local absY = hueBar.AbsolutePosition.Y
                    local szY  = hueBar.AbsoluteSize.Y
                    h = math.clamp((mouse.Y - absY) / szY, 0, 1)
                    updateColor()
                end
            end)

            local cpCloseBtn = Instance.new("TextButton")
            cpCloseBtn.Size = UDim2.new(0, 22, 0, 22)
            cpCloseBtn.AnchorPoint = Vector2.new(1, 0)
            cpCloseBtn.Position = UDim2.new(1, -2, 0, 2)
            cpCloseBtn.BackgroundColor3 = T.BG4
            cpCloseBtn.BackgroundTransparency = 0.3
            cpCloseBtn.Text = ""
            cpCloseBtn.BorderSizePixel = 0
            cpCloseBtn.Parent = pickerArea
            corner(cpCloseBtn, 6)

            local cpCloseIcon = mkCloseIcon(cpCloseBtn, 10, T.SUBTEXT)

            cpCloseBtn.MouseEnter:Connect(function()
                tw(cpCloseBtn, {BackgroundColor3 = T.BG2})
                for _, line in ipairs(cpCloseIcon:GetChildren()) do
                    if line:IsA("Frame") then tw(line, {BackgroundColor3 = T.TEXT}) end
                end
            end)
            cpCloseBtn.MouseLeave:Connect(function()
                tw(cpCloseBtn, {BackgroundColor3 = T.BG4})
                for _, line in ipairs(cpCloseIcon:GetChildren()) do
                    if line:IsA("Frame") then tw(line, {BackgroundColor3 = T.SUBTEXT}) end
                end
            end)

            local open = false

            local function closePicker()
                if not open then return end
                open = false
                -- Hide inner UI instantly for a cleaner close
                pickerArea.Visible = false
                cpCloseBtn.BackgroundTransparency = 1
                svFrame.BackgroundTransparency = 1
                hueBar.BackgroundTransparency = 1
                svPin.BackgroundTransparency = 1
                huePin.BackgroundTransparency = 1
                for _, child in ipairs(infoFrame:GetChildren()) do
                    if child:IsA("TextLabel") then
                        child.TextTransparency = 1
                    end
                end
                for _, line in ipairs(cpCloseIcon:GetChildren()) do
                    if line:IsA("Frame") then
                        line.BackgroundTransparency = 1
                    end
                end
                -- Smooth outer collapse only
                tw(row, {Size = UDim2.new(1,0,0,CLOSED_H)}, 0.34, Enum.EasingStyle.Exponential)
            end

            local function openPicker()
                if open then return end
                open = true
                pickerArea.Visible = true
                -- Reset transparencies before expanding
                cpCloseBtn.BackgroundTransparency = 1
                svFrame.BackgroundTransparency = 1
                hueBar.BackgroundTransparency = 1
                svPin.BackgroundTransparency = 1
                huePin.BackgroundTransparency = 1
                for _, child in ipairs(infoFrame:GetChildren()) do
                    if child:IsA("TextLabel") then child.TextTransparency = 1 end
                end
                for _, line in ipairs(cpCloseIcon:GetChildren()) do
                    if line:IsA("Frame") then line.BackgroundTransparency = 1 end
                end
                -- Expand row and fade in all elements at once
                tw(row, {Size = UDim2.new(1,0,0,OPEN_H)}, 0.35, Enum.EasingStyle.Exponential)
                tw(svFrame, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint)
                tw(svPin, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint)
                tw(hueBar, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint)
                tw(huePin, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint)
                tw(cpCloseBtn, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint)
                for _, line in ipairs(cpCloseIcon:GetChildren()) do
                    if line:IsA("Frame") then tw(line, {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quint) end
                end
                for _, child in ipairs(infoFrame:GetChildren()) do
                    if child:IsA("TextLabel") then tw(child, {TextTransparency = 0}, 0.25, Enum.EasingStyle.Quint) end
                end
            end

            cpCloseBtn.MouseButton1Click:Connect(closePicker)

            local clickArea = Instance.new("TextButton")
            clickArea.Size = UDim2.new(1,0,0,CLOSED_H)
            clickArea.BackgroundTransparency = 1
            clickArea.Text = ""
            clickArea.Parent = row

            clickArea.MouseButton1Click:Connect(function()
                if open then
                    closePicker()
                else
                    openPicker()
                end
            end)

            local cpObj = {
                Set = function(_, col)
                    h, s, v = col:ToHSV()
                    updateColor()
                end,
                Get = function(_) return Color3.fromHSV(h, s, v) end,
            }
            if opts.Flag then registerConfigFlag(opts.Flag, cpObj) end
            return cpObj
        end

        ---------------------------------------------------------------------------
        -- Confirm Button
        ---------------------------------------------------------------------------
        function secObj:AddConfirmButton(opts, cb)
            opts = opts or {}
            cb = cb or function() end
            local row = mkFrame(card, UDim2.new(1,0,0,34), nil, T.BG3)
            registerFeature(opts.Title or "Confirm Button", row)
            corner(row, 7)
            pad(row, 0, 0, 12, 12)
            mkStroke(row, T.HINT, 1, 0.6)

            local lbl2 = mkLabel(row, opts.Title or "Confirm Action", 13, T.TEXT, Enum.TextXAlignment.Left)
            lbl2.Position = UDim2.new(0,0,0,0)

            local arrowHolder = Instance.new("Frame")
            arrowHolder.Size = UDim2.new(0, 20, 0, 20)
            arrowHolder.Position = UDim2.new(1, -24, 0.5, -10)
            arrowHolder.BackgroundTransparency = 1
            arrowHolder.Parent = row
            local arrowIcon = mkArrowIcon(arrowHolder, 16, T.SUBTEXT)

            local btn2 = hoverRow(row, T.BG4, T.BG3)
            btn2.MouseButton1Down:Connect(function()
                tw(row, {BackgroundColor3 = T.ACCENT2})
                tw(lbl2, {TextColor3 = Color3.new(1,1,1)})
                tweenIconColor(arrowIcon, Color3.new(1,1,1))
            end)
            btn2.MouseButton1Click:Connect(function()
                tw(row, {BackgroundColor3 = T.BG3})
                tw(lbl2, {TextColor3 = T.TEXT})
                tweenIconColor(arrowIcon, T.SUBTEXT)
                -- Show confirm dialog instead of calling cb directly
                local confirmOpts = {
                    Title = opts.ConfirmTitle or ("Confirm: " .. (opts.Title or "Action")),
                    Desc = opts.ConfirmDesc or opts.Desc or "Are you sure you want to proceed?",
                    ConfirmText = opts.ConfirmText or "Yes, proceed",
                    CancelText = opts.CancelText or "Cancel",
                }
                if windowSelf._showConfirm then
                    windowSelf._showConfirm(confirmOpts, cb)
                end
            end)
            btn2.MouseLeave:Connect(function()
                tw(row, {BackgroundColor3 = T.BG3})
                tw(lbl2, {TextColor3 = T.TEXT})
                tweenIconColor(arrowIcon, T.SUBTEXT)
            end)
            return {}
        end



        return secObj
    end

    return tabObj
end

---------------------------------------------------------------------------
-- Notification — polished layout & animations
---------------------------------------------------------------------------
function SimpleUI:Notify(opts)
    opts = opts or {}
    local title    = opts.Title    or "Notification"
    local desc     = opts.Desc     or ""
    local duration = opts.Duration or 5
    local kind     = opts.Kind     or "info"

    local accentCol = ({
        info    = T.ACCENT,
        success = T.ON,
        warn    = Color3.fromRGB(220,60,60),
        error   = Color3.fromRGB(220,80,80),
    })[kind] or T.ACCENT

    local iconText = ({
        info    = "ℹ",
        success = "✓",
        warn    = "⚠",
        error   = "✕",
    })[kind] or "ℹ"

    local sg = self._sg or CoreGui:FindFirstChild("SimpleUI_v2")
    if not sg then return end

    local nc = sg:FindFirstChild("_Notifs")
    if not nc then
        nc = Instance.new("Frame")
        nc.Name               = "_Notifs"
        nc.AnchorPoint        = Vector2.new(1,1)
        nc.Position           = UDim2.new(1,-16,1,-16)
        nc.Size               = UDim2.new(0,320,1,-32)
        nc.BackgroundTransparency = 1
        nc.BorderSizePixel    = 0
        nc.Parent             = sg
        local nl = mkList(nc, 8)
        nl.VerticalAlignment  = Enum.VerticalAlignment.Bottom
    end

    local BAR_H = 5
    local n = Instance.new("CanvasGroup")
    n.Size               = UDim2.new(1, 0, 0, 0)
    n.AutomaticSize      = Enum.AutomaticSize.Y
    n.BackgroundColor3   = T.BG2
    n.BackgroundTransparency = 0
    n.BorderSizePixel    = 0
    n.ClipsDescendants   = true
    n.GroupTransparency  = 1
    n.Parent             = nc
    corner(n, 10)
    local stroke = mkStroke(n, accentCol, 1, 1)
    n.Position = UDim2.new(1.2, 0, 0, 0)

    mkList(n, 0)

    local content = mkFrame(n, UDim2.new(1,0,0,0), nil, Color3.new(0,0,0), 1)
    content.AutomaticSize = Enum.AutomaticSize.Y
    content.LayoutOrder  = 1

    local contentPad = Instance.new("UIPadding")
    contentPad.PaddingTop    = UDim.new(0, 14)
    contentPad.PaddingBottom = UDim.new(0, 14)
    contentPad.PaddingLeft   = UDim.new(0, 14)
    contentPad.PaddingRight  = UDim.new(0, 14)
    contentPad.Parent        = content

    local iconCircle = mkFrame(content, UDim2.new(0,28,0,28), UDim2.new(0,0,0,0), accentCol, 0.85)
    corner(iconCircle, 14)

    if kind == "warn" then
        local iconImg = Instance.new("ImageLabel")
        iconImg.BackgroundTransparency = 1
        iconImg.Size = UDim2.new(0,20,0,20)
        iconImg.Position = UDim2.new(0.5,0,0.5,0)
        iconImg.AnchorPoint = Vector2.new(0.5,0.5)
        iconImg.Image = "rbxassetid://7733658271"
        iconImg.ImageColor3 = Color3.new(1,1,1)
        iconImg.ImageTransparency = 0
        iconImg.ScaleType = Enum.ScaleType.Fit
        iconImg.Parent = iconCircle
    elseif kind == "error" then
        local iconImg = Instance.new("ImageLabel")
        iconImg.BackgroundTransparency = 1
        iconImg.Size = UDim2.new(0,20,0,20)
        iconImg.Position = UDim2.new(0.5,0,0.5,0)
        iconImg.AnchorPoint = Vector2.new(0.5,0.5)
        iconImg.Image = "rbxassetid://7733658271"
        iconImg.ImageColor3 = Color3.new(1,1,1)
        iconImg.ImageTransparency = 0
        iconImg.ScaleType = Enum.ScaleType.Fit
        iconImg.Parent = iconCircle
    else
        local iconL = Instance.new("TextLabel")
        iconL.BackgroundTransparency = 1
        iconL.Size = UDim2.new(1,0,1,0)
        iconL.Text = iconText
        iconL.Font = Enum.Font.GothamBold
        iconL.TextSize = 14
        iconL.TextColor3 = accentCol
        iconL.TextTransparency = 0
        iconL.TextXAlignment = Enum.TextXAlignment.Center
        iconL.Parent = iconCircle
    end

    local textWrap = mkFrame(content, UDim2.new(1,-38,0,0), UDim2.new(0,38,0,0), Color3.new(0,0,0), 1)
    textWrap.AutomaticSize = Enum.AutomaticSize.Y
    mkList(textWrap, 4)

    local tl = Instance.new("TextLabel")
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1,0,0,18)
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 13
    tl.TextColor3 = T.TEXT
    tl.TextTransparency = 0
    tl.Text = title
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.TextTruncate = Enum.TextTruncate.AtEnd
    tl.Parent = textWrap

    local dl
    if desc ~= "" then
        dl = Instance.new("TextLabel")
        dl.BackgroundTransparency = 1
        dl.Size = UDim2.new(1,0,0,0)
        dl.AutomaticSize = Enum.AutomaticSize.Y
        dl.Font = Enum.Font.Gotham
        dl.TextSize = 11
        dl.TextColor3 = T.SUBTEXT
        dl.TextTransparency = 0
        dl.Text = desc
        dl.TextXAlignment = Enum.TextXAlignment.Left
        dl.TextWrapped = true
        dl.Parent = textWrap
    end

    local pbarWrap = mkFrame(n, UDim2.new(1, 0, 0, BAR_H + 6), nil, Color3.new(0,0,0), 1)
    pbarWrap.LayoutOrder = 2
    pbarWrap.ClipsDescendants = true
    local pbarPad = Instance.new("UIPadding")
    pbarPad.PaddingLeft  = UDim.new(0, 6)
    pbarPad.PaddingRight = UDim.new(0, 6)
    pbarPad.PaddingBottom = UDim.new(0, 4)
    pbarPad.Parent = pbarWrap
    local pbarTrack = mkFrame(pbarWrap, UDim2.new(1, 0, 0, BAR_H), nil, T.BG4)
    corner(pbarTrack, math.ceil(BAR_H / 2))
    local pbar = mkFrame(pbarTrack, UDim2.new(1,0,1,0), nil, accentCol, 0)
    corner(pbar, math.ceil(BAR_H / 2))

    local FADE_TIME = 0.42

    -- Fade in: whole notification and stroke together
    task.defer(function()
        tw(n, {Position = UDim2.new(0, 0, 0, 0), GroupTransparency = 0}, FADE_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        tw(stroke, {Transparency = 0.4}, FADE_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    end)

    -- Progress bar countdown
    task.delay(FADE_TIME, function()
        tw(pbar, {Size = UDim2.new(0, 0, 1, 0)}, math.max(duration - FADE_TIME, 0.05), Enum.EasingStyle.Linear)
    end)

    -- Fade out: whole notification and stroke together
    task.delay(duration, function()
        tw(n, {GroupTransparency = 1, Position = UDim2.new(1.1, 0, 0, 0)}, FADE_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        tw(stroke, {Transparency = 1}, FADE_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        task.wait(FADE_TIME + 0.05)
        n:Destroy()
    end)
end

