    end

    local function serializeValue(val)
        if typeof(val) == "Color3" then
            return {
                __type = "Color3",
                R = math.round(val.R * 255),
                G = math.round(val.G * 255),
                B = math.round(val.B * 255),
            }
        elseif typeof(val) == "EnumItem" then
            return {
                __type = "EnumItem",
                enumType = tostring(val.EnumType),
                name = val.Name,
            }
        elseif typeof(val) == "table" then
            local arr = {}
            local isArray = true
            local count = 0
            for k, v in pairs(val) do
                count = count + 1
                if type(k) ~= "number" then
                    isArray = false
                    break
                end
            end
            if isArray then
                for i = 1, #val do
                    arr[i] = serializeValue(val[i])
                end
                return {
                    __type = "Array",
                    value = arr,
                }
            end
        elseif typeof(val) == "boolean" or typeof(val) == "number" or typeof(val) == "string" then
            return val
        end
        return nil
    end

    local function deserializeValue(val)
        if type(val) ~= "table" then return val end
        if val.__type == "Color3" and val.R and val.G and val.B then
            return Color3.fromRGB(val.R, val.G, val.B)
        end
        if val.__type == "EnumItem" and val.name then
            for _, enumObj in ipairs(Enum:GetEnums()) do
                if tostring(enumObj) == val.enumType then
                    return enumObj[val.name]
                end
            end
            return nil
        end
        if val.__type == "Array" and type(val.value) == "table" then
            local out = {}
            for i, item in ipairs(val.value) do
                out[i] = deserializeValue(item)
            end
            return out
        end
        return val
    end

    local currentThemeName
    local themeButtons
    local rainbowStroke
    local accentSwatches
    local toggleKey
    local kbBtn

    local function applyThemeState(decoded)
        if decoded.Theme and ThemePresets[decoded.Theme] then
            currentThemeName = decoded.Theme
            applyPreset(decoded.Theme)
        end

        if decoded.Accent then
            local accent = deserializeValue(decoded.Accent)
            if typeof(accent) == "Color3" then
                rainbowActive = false
                T.ACCENT = accent
                local h2, s2, v2 = accent:ToHSV()
                T.ACCENT2 = Color3.fromHSV(h2, math.min(s2 + 0.15, 1), math.max(v2 - 0.15, 0))
            end
        end

        if decoded.AccentAlt then
            local accentAlt = deserializeValue(decoded.AccentAlt)
            if typeof(accentAlt) == "Color3" then
                T.ACCENT2 = accentAlt
            end
        end

        if decoded.ToggleKey then
            local keyVal = deserializeValue(decoded.ToggleKey)
            if typeof(keyVal) == "EnumItem" then
                toggleKey = keyVal
                if kbBtn then
                    kbBtn.Text = keyVal.Name
                    tw(kbBtn, {TextColor3 = T.ACCENT})
                end
            end
        end

        if themeButtons then
            for bName, bData in pairs(themeButtons) do
                local isSel = (bName == currentThemeName)
                tw(bData.stroke, {Color = isSel and T.ACCENT or ThemePresets[bName].HINT, Transparency = isSel and 0 or 0.5})
            end
        end

        if accentSwatches then
            local matchedStatic = false
            for _, swData in ipairs(accentSwatches) do
                local isMatch = math.abs(swData.color.R - T.ACCENT.R) < 0.02 and math.abs(swData.color.G - T.ACCENT.G) < 0.02 and math.abs(swData.color.B - T.ACCENT.B) < 0.02
                if isMatch then matchedStatic = true end
                tw(swData.stroke, {Transparency = isMatch and 0 or 1})
            end
            if rainbowStroke then
                tw(rainbowStroke, {Transparency = matchedStatic and 1 or 0})
            end
        end

        fireThemeChange()
    end

    -- Save current config
    local function saveCurrentConfig(name)
        name = normalizeConfigName(name)
        if name == "" then return false end
        if not writefile then
            warn("[SimpleUI] writefile not available - cannot save config")
            return false
        end
        ensureFolder(configFolder)
        local data = {
            _version = 2,
            Theme = currentThemeName,
            Accent = serializeValue(T.ACCENT),
            AccentAlt = serializeValue(T.ACCENT2),
            ToggleKey = serializeValue(toggleKey),
        }
        local flagCount = 0
        for flagName, flagData in pairs(configFeatures) do
            if flagData.Get then
                local ok, val = pcall(function() return flagData:Get() end)
                if ok then
                    local serialized = serializeValue(val)
                    if serialized ~= nil then
                        data[flagName] = serialized
                        flagCount = flagCount + 1
                    else
                        warn("[SimpleUI] Could not serialize flag:", flagName, typeof(val))
                    end
                else
                    warn("[SimpleUI] Get() failed for flag:", flagName, val)
                end
            end
        end
        local path = getConfigPath(name)
        local jsonStr
        local ok1, err1 = pcall(function() jsonStr = HttpService:JSONEncode(data) end)
        if not ok1 then
            warn("[SimpleUI] JSON encode failed:", err1)
            return false
        end
        local ok, err = pcall(function() writefile(path, jsonStr) end)
        if not ok then
            warn("[SimpleUI] Failed to save:", err)
            return false
        end
        -- Verify the file was written correctly
        if isfile and readfile then
            local vOk, vRaw = pcall(readfile, path)
            if vOk then
                local vOk2, vDecoded = pcall(function() return HttpService:JSONDecode(vRaw) end)
                if vOk2 and type(vDecoded) == "table" then
                    local savedFlags = 0
                    for flagName, _ in pairs(configFeatures) do
                        if vDecoded[flagName] ~= nil then
                            savedFlags = savedFlags + 1
                        end
                    end
                    if savedFlags ~= flagCount then
                        warn("[SimpleUI] Save verification mismatch: expected", flagCount, "flags, found", savedFlags)
                    end
                end
            end
        end
        hiddenDeletedConfigs[name] = nil
        return true
    end

    -- Load a config
    local function loadConfigFromFile(name)
        if not readfile or not isfile then return false end
        local path = getConfigPath(name)
        if not isfile(path) then return false end
        local ok, raw = pcall(readfile, path)
        if not ok then return false end
        local ok2, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok2 or type(decoded) ~= "table" then return false end

        applyThemeState(decoded)

        for flagName, flagData in pairs(configFeatures) do
            local saved = decoded[flagName]
            if saved ~= nil and flagData.Set then
                local deserialized = deserializeValue(saved)
                if deserialized ~= nil then
                    flagData:Set(deserialized)
                end
            end
        end
        -- Re-fire theme change after all flags are set to ensure accent is applied
        fireThemeChange()
        task.defer(fireThemeChange)
        return true
    end

    local function tryApplyPendingAutoload()
        if pendingAutoloadName and pendingAutoloadName ~= "" then
            local ok = loadConfigFromFile(pendingAutoloadName)
            if ok then
                pendingAutoloadName = nil
                return true
            end
        end
        return false
    end

    -- Delete a config
    local function deleteConfig(name)
        name = normalizeConfigName(name)
        if name == "" then return false end

        local path = getConfigPath(name)
        local deleted = false

        if isfile and not isfile(path) then
            hiddenDeletedConfigs[name] = true
            return true
        end

        if delfile then
            local ok = pcall(delfile, path)
            deleted = ok
        end

        if isfile then
            for _ = 1, 6 do
                if not isfile(path) then
                    deleted = true
                    break
                end
                task.wait(0.05)
            end
        end

        if deleted then
            hiddenDeletedConfigs[name] = true
        end

        return deleted
    end

    -- List configs
    local function listConfigs()
        ensureFolder(configFolder)
        local files = {}
        local seen = {}
        if listfiles then
        local ok, result = pcall(listfiles, configFolder)
        if ok and result then
            for _, path in ipairs(result) do
                local name = path:match("([^/\]+)%.json$")
                if name then
                    name = normalizeConfigName(name)
                    local exists = true
                    if isfile then
                        exists = isfile(getConfigPath(name))
                    end
                    if exists and not hiddenDeletedConfigs[name] and not seen[name] then
                        seen[name] = true
                        knownSavedConfigs[name] = true
                        table.insert(files, name)
                    end
                end
            end
        end
        end -- if listfiles
        for name, _ in pairs(knownSavedConfigs) do
            if not seen[name] and not hiddenDeletedConfigs[name] then
                local exists = true
                if isfile then
                    exists = isfile(getConfigPath(name))
                end
                if exists then
                    seen[name] = true
                    table.insert(files, name)
                end
            end
        end
        table.sort(files)
        return files
    end

    -- Register a feature flag for config saving
    local function registerConfigFlag(name, obj)
        if name and obj then
            configFeatures[name] = obj
            task.defer(tryApplyPendingAutoload)
        end
    end
